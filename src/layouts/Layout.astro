---
import "@/styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Sayan Datta — Senior Full Stack Developer & Open Source Engineer",
  description = "Senior Full Stack Developer specializing in high-performance WooCommerce systems, custom payment gateways, Laravel backends, and modern TypeScript (Astro, Next.js). 8+ years experience.",
  image = "https://sayandatta.co.in/favicon.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://sayandatta.co.in");
---

<!doctype html>
<html lang="en" class="scroll-smooth" id="root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Sayan Datta Portfolio" />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@im_sayaan" />
    <meta name="twitter:image" content={image} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300..900&family=JetBrains+Mono:wght@400..700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (!t) {
          t = matchMedia("(prefers-color-scheme:light)").matches ? "light" : "dark";
        }
        if (t === "light") document.documentElement.classList.add("light");
      })();
    </script>

    <!-- Structured Data (JSON-LD) for SEO -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Sayan Datta",
        "url": "https://sayandatta.co.in",
        "image": "https://sayandatta.co.in/favicon.png",
        "sameAs": ["https://github.com/iamsayan", "https://linkedin.com/in/meetsayan", "https://twitter.com/im_sayaan"],
        "jobTitle": "Senior Full Stack Developer",
        "worksFor": {
          "@type": "Organization",
          "name": "TeamUpdraft"
        },
        "description": "Senior Full Stack Developer specializing in high-performance WooCommerce systems, custom payment gateways, Laravel backends, and modern TypeScript (Astro, Next.js)."
      }
    </script>
  </head>
  <body class="min-h-screen relative">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-deep focus:rounded-lg focus:font-bold focus:shadow-lg focus:outline-none"
    >
      Skip to main content
    </a>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <slot />
    </div>

    <!-- Keyboard Shortcuts Modal Overlay -->
    <div
      id="shortcuts-modal"
      class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-deep/80 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300"
      aria-hidden="true"
      role="dialog"
      aria-labelledby="shortcuts-title"
    >
      <div
        class="glass max-w-sm w-full bg-surface border-strong p-6 rounded-2xl shadow-2xl relative transform scale-95 transition-all duration-300"
        id="shortcuts-content"
      >
        <button
          id="close-shortcuts"
          class="absolute top-4 right-4 text-muted hover:text-primary transition-colors cursor-pointer text-xs font-mono"
          aria-label="Close shortcuts help modal"
        >
          &times; ESC
        </button>
        <h3 id="shortcuts-title" class="text-sm font-bold text-primary font-display mb-4 flex items-center gap-2">
          <span>⌨️</span> KEYBOARD SHORTCUTS
        </h3>
        <div class="space-y-3 font-sans">
          <div class="flex justify-between items-center text-xs border-b border-subtle pb-2">
            <span class="text-secondary">Go to Home</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-accent font-bold"
              >1</kbd
            >
          </div>
          <div class="flex justify-between items-center text-xs border-b border-subtle pb-2">
            <span class="text-secondary">Go to Projects</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-accent font-bold"
              >2</kbd
            >
          </div>
          <div class="flex justify-between items-center text-xs border-b border-subtle pb-2">
            <span class="text-secondary">Go to Skills</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-accent font-bold"
              >3</kbd
            >
          </div>
          <div class="flex justify-between items-center text-xs border-b border-subtle pb-2">
            <span class="text-secondary">Go to Services</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-accent font-bold"
              >4</kbd
            >
          </div>
          <div class="flex justify-between items-center text-xs border-b border-subtle pb-2">
            <span class="text-secondary">Go to Blog</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-accent font-bold"
              >5</kbd
            >
          </div>
          <div class="flex justify-between items-center text-xs border-b border-subtle pb-2">
            <span class="text-secondary">Go to About</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-accent font-bold"
              >6</kbd
            >
          </div>
          <div class="flex justify-between items-center text-xs border-b border-subtle pb-2">
            <span class="text-secondary">Go to Contact</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-accent font-bold"
              >7</kbd
            >
          </div>
          <div class="flex justify-between items-center text-xs pt-1">
            <span class="text-muted">Toggle Shortcuts Help</span>
            <kbd class="px-2 py-0.5 rounded bg-raised border border-strong font-mono text-[10px] text-primary font-bold"
              >?</kbd
            >
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      // 1. Console Easter Egg
      console.log(
        "%c Sayan Datta %c Available for hire ",
        "background:#e11d48;color:#fff;padding:4px 8px;font-weight:bold;border-radius:4px 0 0 4px;font-family:sans-serif;",
        "background:#1e293b;color:#f43f5e;padding:4px 8px;border-radius:0 4px 4px 0;font-family:sans-serif;font-weight:600;"
      );
      console.log(
        "%cSpecialist in WooCommerce checkout latency optimizations and payment plugin architectures.",
        "color:#94a3b8;font-family:sans-serif;font-size:11px;"
      );

      // 2. Keyboard Navigation Logic
      (function () {
        const modal = document.getElementById("shortcuts-modal");
        const content = document.getElementById("shortcuts-content");
        const closeBtn = document.getElementById("close-shortcuts");

        function toggleModal(show) {
          if (!modal || !content) return;
          if (show === undefined) show = modal.classList.contains("opacity-0");
          if (show) {
            modal.classList.remove("opacity-0", "pointer-events-none");
            content.classList.remove("scale-95");
            content.classList.add("scale-100");
          } else {
            modal.classList.add("opacity-0", "pointer-events-none");
            content.classList.remove("scale-100");
            content.classList.add("scale-95");
          }
        }

        window.addEventListener("keydown", function (e) {
          // Ignore key shortcuts if user is typing in forms/inputs/textareas
          const active = document.activeElement;
          if (active && (active.tagName === "INPUT" || active.tagName === "TEXTAREA" || active.isContentEditable)) {
            return;
          }

          if (e.key === "?") {
            e.preventDefault();
            toggleModal();
          } else if (e.key === "Escape") {
            toggleModal(false);
          } else if (e.key === "1") {
            window.location.href = "/";
          } else if (e.key === "2") {
            window.location.href = "/projects";
          } else if (e.key === "3") {
            window.location.href = "/skills";
          } else if (e.key === "4") {
            window.location.href = "/services";
          } else if (e.key === "5") {
            window.location.href = "/blog";
          } else if (e.key === "6") {
            window.location.href = "/about-me";
          } else if (e.key === "7") {
            window.location.href = "/contact";
          }
        });

        if (modal) {
          modal.addEventListener("click", function (e) {
            if (e.target === modal) toggleModal(false);
          });
        }
        if (closeBtn) {
          closeBtn.addEventListener("click", function () {
            toggleModal(false);
          });
        }
      })();

      // 3. Quick-Copy Email Helper
      (function () {
        document.addEventListener("click", function (e) {
          const btn = e.target.closest(".copy-email-btn");
          if (!btn) return;
          const email = btn.getAttribute("data-email");
          if (!email) return;

          navigator.clipboard.writeText(email).then(function () {
            const icon = btn.querySelector("svg");
            if (icon) {
              const originalHtml = icon.innerHTML;
              btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" class="text-emerald-500"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>`;
              setTimeout(function () {
                btn.innerHTML = "";
                btn.appendChild(icon);
              }, 2000);
            }
          });
        });
      })();
    </script>
  </body>
</html>
