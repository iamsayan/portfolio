---
import "@/styles/global.css";
import { ThemeScript } from "astro-theme-toggle/components";
import { Seo } from "astro-seo-meta";
import { Schema } from "astro-seo-schema";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  articleData?: {
    pubDate: Date;
    tags?: string[];
  };
}

const {
  title = "Sayan Datta — Senior Full Stack Developer & Open Source Engineer",
  description = "Senior Full Stack Developer specializing in high-performance WooCommerce systems, custom payment gateways, Laravel backends, and modern TypeScript (Astro, Next.js). 8+ years experience.",
  image,
  type = "website",
  articleData,
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.origin : "https://sayandatta.co.in";
const ogImage = image || `${siteUrl}/favicon.png`;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="en" class="scroll-smooth" id="root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <Seo
      title={title}
      description={description}
      facebook={{
        type: type,
        image: ogImage,
        url: canonicalURL.href,
      }}
      twitter={{
        card: "summary_large_image",
        image: ogImage,
        site: "@im_sayaan",
      }}
    />

    <!-- Favicons -->
    <link rel="icon" type="image/jpeg" href="/avatar.jpg" />
    <link rel="shortcut icon" type="image/jpeg" href="/avatar.jpg" />
    <link rel="apple-touch-icon" href="/avatar.jpg" />
    <meta name="theme-color" content="#f43f5e" />

    <link rel="canonical" href={canonicalURL.href} />

    <ThemeScript />
    <ClientRouter />

    <!-- Structured Data (JSON-LD) for SEO -->
    <Schema
      item={{
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Sayan Datta",
        url: siteUrl,
        image: `${siteUrl}/favicon.png`,
        sameAs: ["https://github.com/iamsayan", "https://linkedin.com/in/meetsayan", "https://twitter.com/im_sayaan"],
        jobTitle: "Senior Full Stack Developer",
        worksFor: {
          "@type": "Organization",
          name: "TeamUpdraft",
        },
        description:
          "Senior Full Stack Developer specializing in high-performance WooCommerce systems, custom payment gateways, Laravel backends, and modern TypeScript (Astro, Next.js).",
      }}
    />

    {
      type === "article" && articleData && (
        <Schema
          item={{
            "@context": "https://schema.org",
            "@type": "BlogPosting",
            headline: title,
            description: description,
            image: ogImage,
            datePublished: articleData.pubDate.toISOString(),
            author: {
              "@type": "Person",
              name: "Sayan Datta",
              url: siteUrl,
            },
            publisher: {
              "@type": "Person",
              name: "Sayan Datta",
              url: siteUrl,
            },
            mainEntityOfPage: {
              "@type": "WebPage",
              "@id": canonicalURL.href,
            },
          }}
        />
      )
    }
  </head>
  <body class="min-h-screen relative overflow-x-hidden">
    <!-- Top Progress Bar for ClientRouter navigation -->
    <div id="progress-bar" aria-hidden="true"></div>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-deep focus:rounded-lg focus:font-bold focus:shadow-lg focus:outline-none"
    >
      Skip to main content
    </a>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <slot />
    </div>

    <script is:inline>
      // 1. Console Easter Egg
      console.log(
        "%c Sayan Datta %c Available for hire ",
        "background:#e11d48;color:#fff;padding:4px 8px;font-weight:bold;border-radius:4px 0 0 4px;font-family:sans-serif;",
        "background:#1e293b;color:#f43f5e;padding:4px 8px;border-radius:0 4px 4px 0;font-family:sans-serif;font-weight:600;"
      );
      console.log(
        "%cSpecialist in WooCommerce checkout latency optimizations and payment plugin architectures.",
        "color:#94a3b8;font-family:sans-serif;font-size:11px;"
      );

      // 2. Quick-Copy Email Helper
      (function () {
        document.addEventListener("click", function (e) {
          const btn = e.target.closest(".copy-email-btn");
          if (!btn) return;
          const email = btn.getAttribute("data-email");
          if (!email) return;

          navigator.clipboard.writeText(email).then(function () {
            const icon = btn.querySelector("svg");
            if (icon) {
              const originalHtml = icon.innerHTML;
              btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" class="text-emerald-500"><path d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/></svg>`;
              setTimeout(function () {
                btn.innerHTML = "";
                btn.appendChild(icon);
              }, 2000);
            }
          });
        });
      })();
    </script>

    <script>
      // Centralized IntersectionObserver for page reveal animations
      // Re-runs on every ClientRouter navigation via astro:page-load
      function initReveal() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
              }
            });
          },
          { threshold: 0.05 }
        );
        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      }

      // Run on first load and on every subsequent ClientRouter navigation
      document.addEventListener("astro:page-load", initReveal);
    </script>
    <script is:inline>
      // Top progress bar — hooks into Astro ClientRouter transition lifecycle
      (function () {
        const bar = document.getElementById('progress-bar');
        if (!bar) return;

        let timer = null;
        let width = 0;

        function setWidth(w) {
          width = w;
          bar.style.width = w + '%';
        }

        function startProgress() {
          clearInterval(timer);
          setWidth(0);
          bar.style.opacity = '1';
          bar.style.transition = 'width 0.15s ease';
          setWidth(30);
          // Trickle slowly toward 85%
          timer = setInterval(function () {
            if (width < 85) {
              const inc = (85 - width) * 0.08;
              setWidth(Math.min(width + inc, 85));
            }
          }, 150);
        }

        function finishProgress() {
          clearInterval(timer);
          bar.style.transition = 'width 0.2s ease, opacity 0.4s ease 0.2s';
          setWidth(100);
          setTimeout(function () {
            bar.style.opacity = '0';
            setTimeout(function () { setWidth(0); }, 400);
          }, 200);
        }

        document.addEventListener('astro:before-preparation', startProgress);
        document.addEventListener('astro:page-load', finishProgress);
      })();
    </script>

    <style is:inline>
      #progress-bar {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 9999;
        height: 2.5px;
        width: 0%;
        opacity: 0;
        background: linear-gradient(to right, #f43f5e, #e879f9, #f43f5e);
        background-size: 200% 100%;
        animation: progress-shimmer 1.4s linear infinite;
        pointer-events: none;
        border-radius: 0 2px 2px 0;
      }

      @keyframes progress-shimmer {
        0%   { background-position: 200% center; }
        100% { background-position: -200% center; }
      }
    </style>
  </body>
</html>
