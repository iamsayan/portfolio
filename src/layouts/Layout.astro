---
import "@/styles/global.css";
import DevConsole from "@/components/DevConsole.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Sayan Datta — Full Stack Developer & WordPress Expert",
  description = "Full Stack Developer & WordPress Expert crafting plugins, products, and performant web experiences. 7+ years, 50+ projects, 1M+ plugin downloads."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth" id="root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://sayandatta.dev" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wdth,wght@400..600&family=Outfit:wght@400..800&display=swap" rel="stylesheet" />
    <script is:inline>
      (function(){var t=localStorage.getItem("theme");if(!t){t=matchMedia("(prefers-color-scheme:light)").matches?"light":"dark"}if(t==="light")document.documentElement.classList.add("light")})();
    </script>
  </head>
  <body class="min-h-screen relative">
    <div class="bg-grid"></div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <slot />
    </div>
    <DevConsole />
  </body>
</html>
