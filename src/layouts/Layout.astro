---
import "@/styles/global.css";
import DevConsole from "@/components/DevConsole.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Sayan Datta — Senior Full Stack Developer & Open Source Engineer",
  description = "Senior Full Stack Developer specializing in high-performance WooCommerce systems, custom payment gateways, Laravel backends, and modern TypeScript (Astro, Next.js). 8+ years experience, 1M+ downloads."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth" id="root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Sayan Datta Portfolio" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@im_sayaan" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wdth,wght@400..600&family=Outfit:wght@400..800&display=swap" rel="stylesheet" />
    
    <script is:inline>
      (function(){var t=localStorage.getItem("theme");if(!t){t=matchMedia("(prefers-color-scheme:light)").matches?"light":"dark"}if(t==="light")document.documentElement.classList.add("light")})();
    </script>

    <!-- Structured Data (JSON-LD) for SEO -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Sayan Datta",
        "url": "https://sayandatta.co.in",
        "image": "https://sayandatta.co.in/og-image.jpg",
        "sameAs": [
          "https://github.com/iamsayan",
          "https://linkedin.com/in/meetsayan",
          "https://twitter.com/im_sayaan"
        ],
        "jobTitle": "Senior Full Stack Developer",
        "worksFor": {
          "@type": "Organization",
          "name": "TeamUpdraft"
        },
        "description": "Senior Full Stack Developer specializing in high-performance WooCommerce systems, custom payment gateways, Laravel backends, and modern TypeScript (Astro, Next.js)."
      }
    </script>
  </head>
  <body class="min-h-screen relative">
    <div class="bg-grid"></div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <slot />
    </div>
    <DevConsole />
  </body>
</html>
