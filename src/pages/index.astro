---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getProfile, getStatistics, getProjects } from "@/lib/data";
import { Icon } from "astro-icon/components";

const profile = await getProfile();
const statsData = await getStatistics();
const allProjects = await getProjects();

// Retrieve top 2 featured open source contributions or plugins
const featuredProjects = allProjects.filter((p) => p.featured && p.url.includes("wordpress.org/plugins")).slice(0, 2);

// If there are less than 2, fill with other featured projects
if (featuredProjects.length < 2) {
  const others = allProjects.filter((p) => p.featured && !featuredProjects.includes(p));
  featuredProjects.push(...others);
}

// Keep exactly top 2 for the main hero showcase columns
const mainShowcaseProjects = featuredProjects.slice(0, 2);

// Retrieve exactly 3 non-featured projects/packages/repos for the secondary grid
const secondaryShowcaseProjects = allProjects.filter((p) => !p.featured).slice(0, 3);

const stats = [
  { value: statsData.experience, label: "Professional Experience" },
  { value: statsData.downloads, label: "Plugin Downloads" },
  { value: statsData.projects, label: "Projects Shipped" },
  { value: statsData.repositories, label: "GitHub Repos" },
];
---

<Layout
  title={`${profile.name} | ${profile.title} & Open Source Engineer`}
  description={`${profile.title} specializing in high-performance WooCommerce systems, custom payment gateways, Laravel backends, and modern TypeScript (Astro, Next.js).`}
>
  <Header />
  <main id="main-content">
    <!-- ── Hero — Split Screen Workbench ── -->
    <section class="min-h-screen flex flex-col justify-center relative overflow-hidden pt-20">
      <!-- Colorful Ambient Glow Spotlights -->
      <div
        class="absolute inset-0 opacity-[0.12] pointer-events-none"
        style="background:radial-gradient(circle at 75% 35%, var(--accent), transparent 50%)"
      >
      </div>
      <div
        class="absolute inset-0 opacity-[0.1] pointer-events-none"
        style="background:radial-gradient(circle at 20% 75%, #6366f1, transparent 50%)"
      >
      </div>

      <div class="mx relative z-10 py-16 lg:py-24">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <!-- Left: Pitch & Typography -->
          <div class="lg:col-span-7 space-y-6">
            <div
              class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-accent-glow border border-rose-500/10"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
                ></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
              </span>
              <span class="text-[10px] font-mono tracking-wider text-accent-bright uppercase"
                >Open to Freelance &amp; Contract Work</span
              >
            </div>

            <h1
              class="t-display text-balance text-5xl md:text-7xl font-extrabold tracking-tight leading-none text-primary"
            >
              Product engineering from <span class="t-accent">WordPress to Next.js &amp; Astro.</span>
            </h1>

            <p class="t-body max-w-xl text-lg leading-relaxed">
              I am a <strong class="text-primary font-semibold">Senior Full Stack Developer</strong> with {
                statsData.experience
              } years of experience. I specialize in scaling e-commerce checkouts, custom payment integrations, robust Laravel
              backends, and high-performance modern JavaScript/TypeScript architectures.
            </p>

            <div class="flex flex-wrap gap-4 pt-4">
              <a
                href="/projects"
                class="b b-primary shadow-lg hover:scale-[1.02] active:scale-100 transition-transform"
              >
                Explore Shipped Work
                <Icon name="ph:arrow-right" class="w-4 h-4" aria-hidden="true" />
              </a>

              <a href="/contact" class="b b-ghost hover:scale-[1.02] active:scale-100 transition-transform"
                >Let's talk</a
              >
            </div>

            <!-- Stats Bar Below CTA -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-10 border-t border-subtle">
              {
                stats.map((s) => (
                  <div>
                    <p class="text-3xl md:text-4xl font-black t-accent font-[var(--font-display)]">{s.value}</p>
                    <p class="text-xs text-secondary mt-1">{s.label}</p>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Right: Interactive Developer IDE Mockup -->
          <div class="lg:col-span-5 relative">
            <div
              class="absolute -inset-1.5 bg-gradient-to-r from-rose-500 to-purple-600 rounded-2xl blur-lg opacity-25"
              aria-hidden="true"
            >
            </div>

            <div class="glass glass-glow rounded-xl overflow-hidden shadow-2xl relative z-10 border-strong">
              <!-- IDE Header -->
              <div
                class="bg-[rgba(255,255,255,0.015)] border-b border-subtle px-4 py-3 flex items-center justify-between"
              >
                <div class="flex items-center gap-1.5" aria-hidden="true">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></span>
                </div>
                <div class="text-[10px] font-mono text-muted tracking-wider">meetsayan-workspace</div>
                <div class="w-10"></div>
              </div>

              <!-- Tab Bar -->
              <div class="bg-surface flex border-b border-subtle font-mono text-xs">
                <button
                  class="ide-tab px-4 py-2 border-r border-subtle bg-deep text-accent border-t border-t-accent flex items-center gap-2 cursor-pointer focus:outline-none"
                  data-tab="php"
                >
                  <span class="text-[#21759b]">PHP</span>
                  <span>plugin.php</span>
                </button>
                <button
                  class="ide-tab px-4 py-2 border-r border-subtle bg-surface text-muted flex items-center gap-2 cursor-pointer focus:outline-none hover:text-primary transition-colors"
                  data-tab="ts"
                >
                  <span class="text-[#38bdf8]">TS</span>
                  <span>gateway.ts</span>
                </button>
                <button
                  class="ide-tab px-4 py-2 bg-surface text-muted flex items-center gap-2 cursor-pointer focus:outline-none hover:text-primary transition-colors border-r border-strong"
                  data-tab="json"
                >
                  <span class="text-[#f59e0b]">JSON</span>
                  <span>composer.json</span>
                </button>
              </div>

              <!-- Editor Workspace -->
              <div
                class="p-6 font-mono text-xs text-secondary bg-deep overflow-x-auto min-h-[340px]"
                aria-label="Code Example Workspace"
              >
                <!-- PHP Panel -->
                <div id="code-php" class="code-panel space-y-1">
                  <div><span class="text-[#9333ea]">&lt;?php</span></div>
                  <div>
                    <span class="text-[#3b82f6]">namespace</span>
                    <span class="text-[#e54b4b]">Sayan\WooUPI</span>;
                  </div>
                  <div class="text-muted">/**</div>
                  <div class="text-muted">* WooCommerce UPI payment gateway integration.</div>
                  <div class="text-muted">*/</div>
                  <div>
                    <span class="text-[#9333ea]">class</span>
                    <span class="text-[#10b981]">Gateway</span>
                    <span class="text-[#9333ea]">extends</span>
                    <span class="text-[#38bdf8]">\WC_Payment_Gateway</span> &#123;
                  </div>
                  <div class="pl-4">
                    <span class="text-[#3b82f6]">public</span>
                    <span class="text-[#9333ea]">function</span>
                    <span class="text-[#38bdf8]">__construct</span>() &#123;
                  </div>
                  <div class="pl-8">
                    <span class="text-[#38bdf8]">$this</span>-&gt;<span class="text-secondary">id</span> = <span
                      class="text-[#10b981]">'upi_gateway'</span
                    >;
                  </div>
                  <div class="pl-8">
                    <span class="text-[#38bdf8]">$this</span>-&gt;<span class="text-secondary">method_title</span> = <span
                      class="text-[#10b981]">'UPI Payments'</span
                    >;
                  </div>
                  <div class="pl-8">
                    <span class="text-[#38bdf8]">$this</span>-&gt;<span class="text-secondary">has_fields</span> = <span
                      class="text-[#3b82f6]">false</span
                    >;
                  </div>
                  <div class="pl-4">&#125;</div>
                  <div class="pl-4 pt-2">
                    <span class="text-[#3b82f6]">public</span>
                    <span class="text-[#9333ea]">function</span>
                    <span class="text-[#38bdf8]">process_payment</span>(<span class="text-[#f59e0b]">$order_id</span>)
                    &#123;
                  </div>
                  <div class="pl-8">
                    <span class="text-[#f59e0b]">$order</span> = <span class="text-[#38bdf8]">wc_get_order</span>(<span
                      class="text-[#f59e0b]">$order_id</span
                    >);
                  </div>
                  <div class="pl-8"><span class="text-[#9333ea]">return</span> [</div>
                  <div class="pl-12">
                    <span class="text-[#10b981]">'result'</span> =&gt; <span class="text-[#10b981]">'success'</span>,
                  </div>
                  <div class="pl-12">
                    <span class="text-[#10b981]">'redirect'</span> =&gt; <span class="text-[#38bdf8]">$order</span
                    >-&gt;<span class="text-[#38bdf8]">get_checkout_payment_url</span>(<span class="text-[#3b82f6]"
                      >true</span
                    >)
                  </div>
                  <div class="pl-8">];</div>
                  <div class="pl-4">&#125;</div>
                  <div>&#125;</div>
                  <div class="pt-4 text-muted">
                    $ <span class="text-secondary">php plugin.php</span>
                  </div>
                  <div class="text-success">&gt; Active state: Loaded WooCommerce payment gateway class.</div>
                </div>

                <!-- TS Panel -->
                <div id="code-ts" class="code-panel space-y-1 hidden">
                  <div>
                    <span class="text-[#3b82f6]">import</span> &#123; <span class="text-[#10b981]">useState</span> &#125;
                    <span class="text-[#3b82f6]">from</span>
                    <span class="text-[#10b981]">'react'</span>;
                  </div>
                  <div>
                    <span class="text-[#3b82f6]">import</span>
                    <span class="text-[#9333ea]">type</span> &#123; <span class="text-[#10b981]">CheckoutResponse</span> &#125;
                    <span class="text-[#3b82f6]">from</span>
                    <span class="text-[#10b981]">'./types'</span>;
                  </div>
                  <div class="pt-2">
                    <span class="text-[#9333ea]">export function</span>
                    <span class="text-[#38bdf8]">useUPIGateway</span>(<span class="text-[#f59e0b]">orderId</span>:
                    number) &#123;
                  </div>
                  <div class="pl-4">
                    <span class="text-[#3b82f6]">const</span> [<span class="text-secondary">loading</span>, <span
                      class="text-[#38bdf8]">setLoading</span
                    >] = <span class="text-[#38bdf8]">useState</span>(<span class="text-[#3b82f6]">false</span>);
                  </div>
                  <div class="pt-2 pl-4">
                    <span class="text-[#3b82f6]">const</span>
                    <span class="text-[#38bdf8]">triggerPayment</span> = <span class="text-[#3b82f6]">async</span> () =&gt;
                    &#123;
                  </div>
                  <div class="pl-8">
                    <span class="text-[#38bdf8]">setLoading</span>(<span class="text-[#3b82f6]">true</span>);
                  </div>
                  <div class="pl-8">
                    <span class="text-[#3b82f6]">const</span>
                    <span class="text-secondary">res</span> = <span class="text-[#3b82f6]">await</span>
                    <span class="text-[#38bdf8]">fetch</span>(<span class="text-[#10b981]"
                      >'/wp-json/woo-upi/v1/pay/'</span
                    > + orderId, &#123;
                  </div>
                  <div class="pl-12">method: <span class="text-[#10b981]">'POST'</span></div>
                  <div class="pl-8">&#125;);</div>
                  <div class="pl-8">
                    <span class="text-[#3b82f6]">const</span>
                    <span class="text-secondary">data</span>: CheckoutResponse = <span class="text-[#3b82f6]"
                      >await</span
                    >
                    <span class="text-secondary">res</span>.<span class="text-[#38bdf8]">json</span>();
                  </div>
                  <div class="pl-8"><span class="text-[#9333ea]">if</span> (data.redirect_url) &#123;</div>
                  <div class="pl-12">
                    <span class="text-secondary">window</span>.<span class="text-secondary">location</span>.<span
                      class="text-secondary">href</span
                    > = data.redirect_url;
                  </div>
                  <div class="pl-8">&#125;</div>
                  <div class="pl-8">
                    <span class="text-[#38bdf8]">setLoading</span>(<span class="text-[#3b82f6]">false</span>);
                  </div>
                  <div class="pl-4">&#125;;</div>
                  <div class="pl-4">
                    <span class="text-[#9333ea]">return</span> &#123; triggerPayment, loading &#125;;
                  </div>
                  <div>&#125;</div>
                  <div class="pt-4 text-muted">$ <span class="text-secondary">tsc gateway.ts --noEmit</span></div>
                  <div class="text-success">&gt; Compilation successful. Zero types error.</div>
                </div>

                <!-- JSON Panel -->
                <div id="code-json" class="code-panel space-y-1 hidden">
                  <div>&#123;</div>
                  <div class="pl-4">"name": <span class="text-[#10b981]">"iamsayan/woo-upi-gateway"</span>,</div>
                  <div class="pl-4">
                    "description": <span class="text-[#10b981]">"UPI payment gateway for WooCommerce checkout."</span>,
                  </div>
                  <div class="pl-4">"type": <span class="text-[#10b981]">"wordpress-plugin"</span>,</div>
                  <div class="pl-4">"require": &#123;</div>
                  <div class="pl-8">"php": <span class="text-[#10b981]">&quot;&gt;=7.4&quot;</span>,</div>
                  <div class="pl-8">"composer/installers": <span class="text-[#10b981]">&quot;^2.0&quot;</span></div>
                  <div class="pl-4">&#125;,</div>
                  <div class="pl-4">"autoload": &#123;</div>
                  <div class="pl-8">"psr-4": &#123;</div>
                  <div class="pl-12">"Sayan\\WooUPI\\": <span class="text-[#10b981]">"src/"</span></div>
                  <div class="pl-8">&#125;</div>
                  <div class="pl-4">&#125;</div>
                  <div>&#125;</div>
                  <div class="pt-4 text-muted">$ <span class="text-secondary">composer validate</span></div>
                  <div class="text-success">&gt; composer.json is valid.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
        <span class="t-mono text-[9px] tracking-widest text-muted">Scroll Down</span>
        <Icon name="ph:caret-double-down" class="w-4 h-4 animate-bounce text-accent" aria-hidden="true" />
      </div>
    </section>

    <!-- ── Services section with custom UI mockups ── -->
    <section class="py-28 relative border-t border-subtle">
      <div class="mx">
        <div class="max-w-2xl">
          <p class="t-mono text-accent uppercase font-bold">Services</p>
          <h2 class="t-display text-4xl md:text-5xl font-extrabold tracking-tight leading-none text-primary mt-3">
            Full-stack <span class="t-accent">competencies.</span>
          </h2>
          <p class="t-body mt-4">
            I deliver performance-first solutions tailored to modern infrastructure and developer experience guidelines.
          </p>
        </div>

        <div class="space-y-24 mt-20">
          <!-- Frontend -->
          <div class="grid lg:grid-cols-12 gap-10 items-center reveal">
            <div class="lg:col-span-5 space-y-5">
              <span
                class="inline-block text-xs font-mono px-3 py-1 rounded-md bg-[rgba(59,130,246,0.1)] text-blue-500 border border-blue-500/10"
                >01 &mdash; FRONTEND</span
              >
              <h3 class="t-title text-2xl font-bold">Frontend Development</h3>
              <p class="t-body">
                Pixel-perfect, accessible, and fast interfaces. Built using modern frameworks like Astro, Next.js, and
                React. Focus on responsive, device-independent layouts and animations.
              </p>
              <div class="flex flex-wrap gap-2 pt-2">
                <span class="tag">Next.js</span><span class="tag">React</span><span class="tag">Astro</span><span
                  class="tag">TypeScript</span
                ><span class="tag">Tailwind CSS</span>
              </div>
            </div>

            <div class="lg:col-span-7 relative">
              <div
                class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-2xl blur-md opacity-20"
                aria-hidden="true"
              >
              </div>
              <div
                class="glass glass-glow rounded-xl overflow-hidden shadow-2xl relative z-10 border-strong p-6 bg-surface"
              >
                <!-- Mock Dashboard Component -->
                <div class="flex items-center justify-between border-b border-subtle pb-4 mb-6">
                  <span class="text-xs font-mono text-primary">lighthouse-performance-audit</span>
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-success-glow text-success">Score: 100%</span
                  >
                </div>
                <div class="grid grid-cols-3 gap-4 mb-6">
                  <div class="p-4 rounded-lg bg-deep border border-subtle">
                    <p class="text-[10px] font-mono text-muted uppercase">FCP</p>
                    <p class="text-lg font-bold text-success mt-1">0.2s</p>
                  </div>
                  <div class="p-4 rounded-lg bg-deep border border-subtle">
                    <p class="text-[10px] font-mono text-muted uppercase">LCP</p>
                    <p class="text-lg font-bold text-success mt-1">0.5s</p>
                  </div>
                  <div class="p-4 rounded-lg bg-deep border border-subtle">
                    <p class="text-[10px] font-mono text-muted uppercase">CLS</p>
                    <p class="text-lg font-bold text-success mt-1">0.00</p>
                  </div>
                </div>
                <!-- glowing line chart -->
                <div class="h-28 rounded-lg bg-deep border border-subtle p-4 flex flex-col justify-between">
                  <div class="flex justify-between items-center text-[9px] font-mono text-muted">
                    <span>Astro Core Vitals load speed (ms)</span>
                    <span class="text-blue-500">Perfect Score</span>
                  </div>
                  <svg class="w-full h-16 mt-2" viewBox="0 0 400 60" fill="none">
                    <path
                      d="M0 50 C 40 45, 80 15, 120 18 C 160 21, 200 48, 240 10 C 280 -8, 320 5, 360 8 L 400 4"
                      stroke="#3b82f6"
                      stroke-width="2"
                      stroke-linecap="round"></path>
                    <path
                      d="M0 50 C 40 45, 80 15, 120 18 C 160 21, 200 48, 240 10 C 280 -8, 320 5, 360 8 L 400 4 L 400 60 L 0 60 Z"
                      fill="url(#blueGrad)"
                      opacity="0.1"></path>
                    <defs>
                      <linearGradient id="blueGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#3b82f6"></stop>
                        <stop offset="100%" stop-color="transparent"></stop>
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <!-- Backend -->
          <div class="grid lg:grid-cols-12 gap-10 items-center reveal">
            <div class="lg:col-span-5 lg:order-2 space-y-5">
              <span
                class="inline-block text-xs font-mono px-3 py-1 rounded-md bg-[rgba(16,185,129,0.1)] text-emerald-500 border border-emerald-500/10"
                >02 &mdash; BACKEND</span
              >
              <h3 class="t-title text-2xl font-bold">Backend Architecture</h3>
              <p class="t-body">
                Designing scalable REST/GraphQL APIs, database queries, and modular services. Building robust systems
                using Laravel, Node.js, and relational databases.
              </p>
              <div class="flex flex-wrap gap-2 pt-2">
                <span class="tag">PHP</span><span class="tag">Laravel</span><span class="tag">Node.js</span><span
                  class="tag">PostgreSQL</span
                ><span class="tag">MySQL</span>
              </div>
            </div>

            <div class="lg:col-span-7 lg:order-1 relative">
              <div
                class="absolute -inset-1 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl blur-md opacity-20"
                aria-hidden="true"
              >
              </div>
              <div
                class="glass glass-glow rounded-xl overflow-hidden shadow-2xl relative z-10 border-strong p-6 bg-surface"
              >
                <!-- Mock API Client -->
                <div class="flex items-center gap-2 border-b border-subtle pb-4 mb-4">
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-[rgba(16,185,129,0.1)] text-success"
                    >GET</span
                  >
                  <span class="text-xs font-mono text-secondary">https://api.sayandatta.co.in/v1/health</span>
                </div>
                <div class="rounded-lg bg-deep p-4 font-mono text-xs text-secondary border border-subtle">
                  <div class="space-y-1">
                    <div>&#123;</div>
                    <div class="pl-4">
                      "status": <span class="text-success">"operational"</span>,
                    </div>
                    <div class="pl-4">
                      "latency_ms": <span class="text-[#f59e0b]">9</span>,
                    </div>
                    <div class="pl-4">
                      "database": <span class="text-success">"connected"</span>,
                    </div>
                    <div class="pl-4">
                      "cache_driver": <span class="text-success">"redis"</span>,
                    </div>
                    <div class="pl-4">
                      "jobs_queue": <span class="text-success">"active"</span>
                    </div>
                    <div>&#125;</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- WordPress -->
          <div class="grid lg:grid-cols-12 gap-10 items-center reveal">
            <div class="lg:col-span-5 space-y-5">
              <span
                class="inline-block text-xs font-mono px-3 py-1 rounded-md bg-[rgba(245,158,11,0.1)] text-amber-500 border border-amber-500/10"
                >03 &mdash; WORDPRESS</span
              >
              <h3 class="t-title text-2xl font-bold">WordPress Engineering</h3>
              <p class="t-body">
                Architecting custom plugins, Gutenberg blocks, headless CMS configurations, and WooCommerce extensions.
                Active contributor to WordPress core since 2018.
              </p>
              <div class="flex flex-wrap gap-2 pt-2">
                <span class="tag">WordPress</span><span class="tag">Gutenberg Blocks</span><span class="tag"
                  >WooCommerce</span
                ><span class="tag">WP-CLI</span><span class="tag">Composer</span>
              </div>
            </div>

            <div class="lg:col-span-7 relative">
              <div
                class="absolute -inset-1 bg-gradient-to-r from-amber-500 to-orange-600 rounded-2xl blur-md opacity-20"
                aria-hidden="true"
              >
              </div>
              <div
                class="glass glass-glow rounded-xl overflow-hidden shadow-2xl relative z-10 border-strong p-6 bg-surface"
              >
                <!-- WordPress Plugin Card Mockup -->
                <div class="flex justify-between items-start border-b border-subtle pb-4 mb-4">
                  <div class="flex items-center gap-3">
                    <div
                      class="w-9 h-9 rounded bg-[#21759b] text-white flex items-center justify-center font-bold text-lg"
                    >
                      W
                    </div>
                    <div>
                      <h4 class="text-sm font-bold text-primary">WP Last Modified Info</h4>
                      <p class="text-[10px] font-mono text-muted">Official Plugin Directory</p>
