<script>

  // IDE Mockup Tab Switcher Logic
  const tabs = document.querySelectorAll(".ide-tab");
  const panels = document.querySelectorAll(".code-panel");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = tab.getAttribute("data-tab");

      tabs.forEach((t) => {
        t.classList.remove("active", "bg-deep", "text-accent", "border-t", "border-t-accent");
        t.classList.add("bg-surface", "text-muted");
      });

      tab.classList.add("active", "bg-deep", "text-accent", "border-t", "border-t-accent");
      tab.classList.remove("bg-surface", "text-muted");

      panels.forEach((p) => {
        if (p.id === `code-${target}`) {
          p.classList.remove("hidden");
        } else {
          p.classList.add("hidden");
        }
      });
    });
  });

  // GitHub telemetry fetching logic
  let gitFetched = false;
  const gitTabBtn = document.getElementById("git-tab-btn");
  if (gitTabBtn) {
    gitTabBtn.addEventListener("click", () => {
      if (!gitFetched) {
        gitFetched = true;
        fetchGitHubEvents();
      }
    });
  }

  async function fetchGitHubEvents() {
    const container = document.getElementById("git-log-content");
    if (!container) return;

    try {
      const res = await fetch("https://api.github.com/users/iamsayan/events/public");
      if (!res.ok) {
        throw new Error(`Failed to fetch events: ${res.status}`);
      }
      const data = await res.json();
      
      // Filter for interactive events
      const validEvents = data.filter((e: any) => 
        e.type === "PushEvent" || 
        e.type === "CreateEvent" || 
        e.type === "PullRequestEvent" || 
        e.type === "IssuesEvent"
      ).slice(0, 4);

      if (validEvents.length === 0) {
        renderFallbackLogs(container);
        return;
      }

      container.innerHTML = "";
      validEvents.forEach((event: any) => {
        const commitCard = createGitLogCard(event);
        container.appendChild(commitCard);
      });
    } catch (err) {
      console.warn("GitHub fetch failed or rate-limited. Falling back to cached logs...", err);
      renderFallbackLogs(container);
    }
  }

  function createGitLogCard(event: any) {
    const card = document.createElement("div");
    card.className = "border-l-2 border-subtle pl-3 py-1 space-y-1 hover:border-accent transition-colors";

    // Extract event details
    let sha = "commit " + (event.id ? event.id.slice(0, 7) : "abcdefg");
    let branch = " (main)";
    let repoName = event.repo.name;
    let repoUrl = `https://github.com/${repoName}`;
    let timeAgo = formatTimeAgo(new Date(event.created_at));
    let message = "";
    
    if (event.type === "PushEvent" && event.payload.commits && event.payload.commits.length > 0) {
      sha = "commit " + event.payload.commits[0].sha.slice(0, 7);
      const branchRef = event.payload.ref || "refs/heads/main";
      branch = ` (${branchRef.replace("refs/heads/", "")})`;
      message = event.payload.commits[0].message;
    } else if (event.type === "CreateEvent") {
      message = `Created repository ${repoName} (${event.payload.description || "No description"})`;
    } else if (event.type === "PullRequestEvent") {
      message = `${event.payload.action} Pull Request #${event.payload.number}: ${event.payload.pull_request.title}`;
    } else {
      message = `Activity on ${repoName}`;
    }

    card.innerHTML = `
      <div class="flex items-center gap-1.5 flex-wrap select-none">
        <span class="text-[#f59e0b] font-bold">${sha}</span>
        <span class="text-[#38bdf8] font-mono text-[10px]">${branch}</span>
      </div>
      <div class="text-muted text-[10px] select-none">
        Author: Sayan Datta &lt;iamsayan&gt; | ${timeAgo}
      </div>
      <div class="text-primary font-medium mt-1 font-sans pl-1">
        ${escapeHtml(message)}
      </div>
      <div class="text-[9px] font-mono text-muted select-none">
        repo: <a href="${repoUrl}" target="_blank" rel="noopener noreferrer" class="text-[#10b981] hover:underline">${repoName}</a>
      </div>
    `;

    return card;
  }

  function formatTimeAgo(date: Date) {
    const now = new Date();
    const seconds = Math.floor((now.getTime() - date.getTime()) / 1000);
    if (seconds < 60) return "Just now";
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    if (days === 1) return "Yesterday";
    return `${days}d ago`;
  }

  function escapeHtml(unsafe: string) {
    return unsafe
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function renderFallbackLogs(container: HTMLElement) {
    container.innerHTML = `
      <div class="text-muted text-[10px] select-none italic pb-2 border-b border-subtle/30">
        API limit exceeded or offline. Showing recent cached logs from git history:
      </div>
      
      <div class="border-l-2 border-accent pl-3 py-1 space-y-1">
        <div class="flex items-center gap-1.5 flex-wrap select-none">
          <span class="text-[#f59e0b] font-bold">commit 9c2a7f1</span>
          <span class="text-[#38bdf8] font-mono text-[10px]"> (main)</span>
        </div>
        <div class="text-muted text-[10px] select-none">Author: Sayan Datta &lt;iamsayan&gt; | 2d ago</div>
        <div class="text-primary font-medium mt-1 font-sans pl-1">
          perf: optimize sticky sidebar layout constraints
        </div>
        <div class="text-[9px] font-mono text-muted select-none">
          repo: <a href="https://github.com/iamsayan/portfolio" target="_blank" rel="noopener noreferrer" class="text-[#10b981] hover:underline">iamsayan/portfolio</a>
        </div>
      </div>

      <div class="border-l-2 border-subtle pl-3 py-1 space-y-1">
        <div class="flex items-center gap-1.5 flex-wrap select-none">
          <span class="text-[#f59e0b] font-bold">commit b82f4d1</span>
          <span class="text-[#38bdf8] font-mono text-[10px]"> (main)</span>
        </div>
        <div class="text-muted text-[10px] select-none">Author: Sayan Datta &lt;iamsayan&gt; | 2d ago</div>
        <div class="text-primary font-medium mt-1 font-sans pl-1">
          fix: typescript Element style compilation check
        </div>
        <div class="text-[9px] font-mono text-muted select-none">
          repo: <a href="https://github.com/iamsayan/portfolio" target="_blank" rel="noopener noreferrer" class="text-[#10b981] hover:underline">iamsayan/portfolio</a>
        </div>
      </div>

      <div class="border-l-2 border-subtle pl-3 py-1 space-y-1">
        <div class="flex items-center gap-1.5 flex-wrap select-none">
          <span class="text-[#f59e0b] font-bold">commit f28a9b3</span>
          <span class="text-[#38bdf8] font-mono text-[10px]"> (main)</span>
        </div>
        <div class="text-muted text-[10px] select-none">Author: Sayan Datta &lt;iamsayan&gt; | 3d ago</div>
        <div class="text-primary font-medium mt-1 font-sans pl-1">
          feat: add interactive service detail explorer panels
        </div>
        <div class="text-[9px] font-mono text-muted select-none">
          repo: <a href="https://github.com/iamsayan/portfolio" target="_blank" rel="noopener noreferrer" class="text-[#10b981] hover:underline">iamsayan/portfolio</a>
        </div>
      </div>
    `;
  }
</script>
