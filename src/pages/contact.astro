---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getProfile, getFAQs } from "@/lib/data";
import { Icon } from "astro-icon/components";
import PageHero from "@/components/PageHero.astro";

const profile = await getProfile();
const faqs = await getFAQs();
---

<Layout
  title="Contact | Let's Build Together"
  description="Get in touch for plugin consulting, API migrations, payment integrations, or backend engineering roles."
>
  <Header />
  <main
    class="py-24 relative overflow-x-clip"
    id="main-content"
    data-email={profile.email}
  >
    <PageHero
      badge="Project Handshake"
      description="Have a plugin concept, API architecture requirement, or technical bottleneck you need resolved? Send a message and let's coordinate."
    >
      <Fragment slot="title">Let's build <span class="t-accent">together.</span></Fragment>
    </PageHero>

    <section class="pb-24 relative z-10">
      <div class="mx">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
          <!-- Left Panel: Context & Details -->
          <div class="lg:col-span-5 self-stretch">
            <div class="lg:sticky lg:top-28 space-y-8">
              <!-- Context Info blocks -->
              <div class="space-y-4 reveal r3">
                <div class="glass p-5 bg-surface border-subtle flex items-start gap-4">
                  <span
                    class="w-8 h-8 rounded bg-accent-glow text-accent flex items-center justify-center flex-shrink-0"
                    aria-hidden="true"
                  >
                    <Icon name="ph:envelope" class="w-4 h-4" />
                  </span>
                  <div>
                    <p class="text-[10px] font-mono text-muted uppercase tracking-wider">Direct Channels</p>
                    <div class="flex items-center gap-2 mt-1">
                      <a
                        href={`mailto:${profile.email}`}
                        class="text-sm font-semibold text-accent hover:text-accent-bright transition-colors block"
                        >{profile.email}</a
                      >
                      <button
                        class="copy-email-btn text-muted hover:text-accent transition-colors cursor-pointer flex items-center justify-center p-0.5 rounded"
                        data-email={profile.email}
                        aria-label="Copy email to clipboard"
                      >
                        <Icon name="ph:copy" class="w-3.5 h-3.5" />
                      </button>
                    </div>
                  </div>
                </div>

                <div class="glass p-5 bg-surface border-subtle flex items-start gap-4">
                  <span
                    class="w-8 h-8 rounded bg-accent-glow text-accent flex items-center justify-center flex-shrink-0"
                    aria-hidden="true"
                  >
                    <Icon name="ph:map-pin" class="w-4 h-4" />
                  </span>
                  <div>
                    <p class="text-[10px] font-mono text-muted uppercase tracking-wider">Operational Location</p>
                    <p class="text-sm text-secondary mt-1 font-semibold">
                      {profile.location} &middot; Remote operations globally
                    </p>
                  </div>
                </div>

                <div class="glass p-5 bg-surface border-subtle flex items-start gap-4">
                  <span
                    class="w-8 h-8 rounded bg-success-glow text-success flex items-center justify-center flex-shrink-0 animate-pulse"
                    aria-hidden="true"
                  >
                    <Icon name="ph:circle-fill" class="w-2.5 h-2.5" />
                  </span>
                  <div>
                    <p class="text-[10px] font-mono text-muted uppercase tracking-wider">Work Availability</p>
                    <p class="text-sm text-secondary mt-1 font-semibold">Open for Freelance and Contract roles</p>
                  </div>
                </div>
              </div>

              <div class="flex items-center gap-6 pt-4 reveal r4">
                <a
                  href={profile.socials.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs font-mono text-secondary hover:text-accent transition-colors"
                  aria-label="Github Profile">&lt; GitHub &gt;</a
                >
                <a
                  href={profile.socials.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs font-mono text-secondary hover:text-accent transition-colors"
                  aria-label="LinkedIn Profile">&lt; LinkedIn &gt;</a
                >
                <a
                  href={profile.socials.twitter}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs font-mono text-secondary hover:text-accent transition-colors"
                  aria-label="Twitter Profile">&lt; Twitter &gt;</a
                >
              </div>
            </div>
          </div>

          <!-- Right Panel: Interactive Form Console -->
          <div class="lg:col-span-7 relative">
            <div class="glass hover-glow-rose p-8 bg-surface border-subtle reveal r2" id="contact-console">
              <!-- Form header -->
              <div class="flex items-center justify-between border-b border-subtle pb-4 mb-6">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-success animate-pulse" aria-hidden="true"></span>
                  <span class="text-xs font-mono text-primary">secure-contact-session (TLS 1.3)</span>
                </div>
                <span class="text-[10px] font-mono text-muted">{Astro.site ? Astro.site.host : "sayandatta.co.in"}</span>
              </div>

              <!-- Contact Form -->
              <form id="contact-form" class="space-y-5">
                <!-- Floating Label Name -->
                <div class="relative">
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 bg-deep border border-subtle focus:border-accent focus:outline-none rounded-lg text-sm transition-all peer placeholder-transparent focus-visible:ring-2 focus-visible:ring-accent"
                    placeholder="Name"
                  />
                  <label
                    for="name"
                    class="absolute left-4 top-0 text-[10px] text-muted -translate-y-2 bg-deep px-1 scale-95 transition-all duration-200 pointer-events-none origin-left peer-placeholder-shown:text-sm peer-placeholder-shown:top-3 peer-placeholder-shown:translate-y-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:px-0 peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-accent peer-focus:-translate-y-2 peer-focus:scale-95 peer-focus:px-1"
                    >Your Name</label
                  >
                </div>

                <!-- Honeypot (Spam mitigation) -->
                <div class="hidden" aria-hidden="true">
                  <input
                    type="text"
                    id="_honeypot"
                    name="_honeypot"
                    tabindex="-1"
                    autocomplete="off"
                    class="hidden"
                  />
                </div>

                <!-- Floating Label Email -->
                <div class="relative">
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 bg-deep border border-subtle focus:border-accent focus:outline-none rounded-lg text-sm transition-all peer placeholder-transparent focus-visible:ring-2 focus-visible:ring-accent"
                    placeholder="Email"
                  />
                  <label
                    for="email"
                    class="absolute left-4 top-0 text-[10px] text-muted -translate-y-2 bg-deep px-1 scale-95 transition-all duration-200 pointer-events-none origin-left peer-placeholder-shown:text-sm peer-placeholder-shown:top-3 peer-placeholder-shown:translate-y-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:px-0 peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-accent peer-focus:-translate-y-2 peer-focus:scale-95 peer-focus:px-1"
                    >Email Address</label
                  >
                </div>

                <!-- Floating Label Scope -->
                <div class="relative">
                  <input
                    type="text"
                    id="scope"
                    name="scope"
                    required
                    class="w-full px-4 py-3 bg-deep border border-subtle focus:border-accent focus:outline-none rounded-lg text-sm transition-all peer placeholder-transparent focus-visible:ring-2 focus-visible:ring-accent"
                    placeholder="Scope"
                  />
                  <label
                    for="scope"
                    class="absolute left-4 top-0 text-[10px] text-muted -translate-y-2 bg-deep px-1 scale-95 transition-all duration-200 pointer-events-none origin-left peer-placeholder-shown:text-sm peer-placeholder-shown:top-3 peer-placeholder-shown:translate-y-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:px-0 peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-accent peer-focus:-translate-y-2 peer-focus:scale-95 peer-focus:px-1"
                    >Project Scope</label
                  >
                </div>

                <!-- Message Details -->
                <div class="relative">
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    required
                    class="w-full px-4 py-3 bg-deep border border-subtle focus:border-accent focus:outline-none rounded-lg text-sm transition-all peer placeholder-transparent focus-visible:ring-2 focus-visible:ring-accent"
                    placeholder="Message"></textarea>
                  <label
                    for="message"
                    class="absolute left-4 top-0 text-[10px] text-muted -translate-y-2 bg-deep px-1 scale-95 transition-all duration-200 pointer-events-none origin-left peer-placeholder-shown:text-sm peer-placeholder-shown:top-3 peer-placeholder-shown:translate-y-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:px-0 peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-accent peer-focus:-translate-y-2 peer-focus:scale-95 peer-focus:px-1"
                    >Project Details / Requirements</label
                  >
                </div>

                <button
                  type="submit"
                  class="b b-primary w-full py-3 shadow-md mt-2 relative overflow-hidden transition-all focus-visible:ring-2 focus-visible:ring-accent cursor-pointer animate-glow"
                  id="submit-btn"
                >
                  <span id="btn-text">Transmit Request</span>
                </button>
              </form>

              <!-- Interactive loading state -->
              <div
                id="loading-state"
                class="hidden py-12 flex flex-col items-center justify-center space-y-4"
                role="status"
              >
                <div class="w-8 h-8 rounded-full border-2 border-subtle border-t-accent animate-spin"></div>
                <p class="text-xs font-mono text-accent" id="loading-log">Preparing payload...</p>
                <div class="w-64 bg-deep h-1 rounded overflow-hidden border border-subtle mt-2">
                  <div id="loading-bar" class="h-full bg-accent transition-all duration-300" style="width: 0%"></div>
                </div>
              </div>

              <!-- Success window overlay -->
              <div id="success-state" class="hidden py-8 text-center space-y-6" role="status">
                <div
                  class="w-12 h-12 rounded-full bg-success-glow text-success flex items-center justify-center mx-auto border border-[rgba(16,185,129,0.2)]"
                >
                  <Icon name="ph:check" class="w-5 h-5" aria-hidden="true" />
                </div>
                <div>
                  <h3 class="text-md font-bold text-primary">Message Transmitted Successfully</h3>
                  <p class="text-xs text-secondary mt-2 max-w-sm mx-auto">
                    Your request has been successfully processed and forwarded to Sayan Datta's primary inbox. You
                    should receive a direct follow-up shortly.
                  </p>
                </div>
                <button id="close-success-btn" class="b b-ghost text-xs py-2 px-4">Submit another request</button>
              </div>

              <!-- Error state & Fallback panel -->
              <div id="error-state" class="hidden py-8 text-center space-y-6" role="alert">
                <div
                  class="w-12 h-12 rounded-full bg-red-500/10 text-red-500 flex items-center justify-center mx-auto border border-red-500/20"
                >
                  <Icon name="ph:warning" class="w-5 h-5" aria-hidden="true" />
                </div>
                <div>
                  <h3 class="text-md font-bold text-primary">Transmission Interrupted</h3>
                  <p id="error-message" class="text-xs text-secondary mt-2 max-w-sm mx-auto">
                    We encountered an issue routing your form details via Formspree API layers.
                  </p>
                </div>
                <div class="space-y-2">
                  <button id="fallback-email-btn" class="b b-primary w-full py-2.5 text-xs shadow-md"
                    >Open Fallback Email Draft</button
                  >
                  <button id="retry-btn" class="b b-ghost text-xs py-2 px-4 w-full text-center">Return to Form</button>
                </div>
              </div>

              <!-- Live Interactive Status Terminal Footer -->
              <div class="mt-6 border border-subtle rounded-lg bg-deep p-4 font-mono text-[10px] text-secondary">
                <div class="flex items-center justify-between text-muted border-b border-subtle pb-2 mb-2 select-none">
                  <span>LIVE COMPILER DEPLOY SHELL</span>
                  <span>v1.2.0-stable</span>
                </div>
                <div id="terminal-feed" class="space-y-1 min-h-[90px] text-muted">
                  <div class="text-success">&gt; session_init: listening on inputs...</div>
                  <div class="text-muted">&gt; waiting_for_user_handshake...</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQs Section -->
    <section class="pb-24 border-t border-subtle pt-20 relative z-10 reveal">
      <div class="mx-narrow">
        <div class="text-center mb-12">
          <p class="t-mono text-accent uppercase">Frequently Asked Questions</p>
          <h2 class="t-title text-2xl font-bold mt-2">Common developer queries.</h2>
        </div>
        <div class="space-y-4">
          {
            faqs.map((faq, fi) => (
              <div
                class="glass p-6 bg-surface border-subtle cursor-pointer group transition-all"
                data-faq={fi}
                tabindex="0"
                role="button"
                aria-expanded="false"
                aria-controls={`faq-ans-${fi}`}
              >
                <div class="flex items-center justify-between">
                  <h3 class="font-bold text-sm text-primary group-hover:text-accent transition-colors">{faq.q}</h3>
                  <span
                    class="text-xs text-muted font-mono transition-transform duration-300 select-none faq-plus"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </div>
                <div
                  id={`faq-ans-${fi}`}
                  class="faq-answer-grid faq-answer"
                >
                  <div class="overflow-hidden">
                    <p class="text-xs text-secondary mt-4 leading-relaxed font-sans">{faq.a}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* CSS Grid based FAQ Accordion Transition */
  .faq-answer-grid {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 300ms cubic-bezier(0.4, 0, 0.2, 1), opacity 250ms ease;
  }
  .faq-open .faq-answer-grid {
    grid-template-rows: 1fr;
    opacity: 1;
  }
</style>

<script>
  import { actions } from "astro:actions";

  function initContactForm() {
    const contactForm = document.getElementById("contact-form") as HTMLFormElement;
    if (!contactForm) return;

    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const loadingState = document.getElementById("loading-state");
    const loadingLog = document.getElementById("loading-log");
    const loadingBar = document.getElementById("loading-bar");
    const successState = document.getElementById("success-state");
    const closeSuccessBtn = document.getElementById("close-success-btn");
    const errorState = document.getElementById("error-state");
    const errorMessage = document.getElementById("error-message");
    const fallbackEmailBtn = document.getElementById("fallback-email-btn");
    const retryBtn = document.getElementById("retry-btn");
    const mainEl = document.getElementById("main-content");
    const emailAddr = mainEl?.getAttribute("data-email") || "hello@sayandatta.co.in";
    const terminalFeed = document.getElementById("terminal-feed");

    // Inputs
    const nameInput = document.getElementById("name") as HTMLInputElement;
    const emailInput = document.getElementById("email") as HTMLInputElement;
    const scopeInput = document.getElementById("scope") as HTMLInputElement;
    const messageInput = document.getElementById("message") as HTMLTextAreaElement;
    const honeypotInput = document.getElementById("_honeypot") as HTMLInputElement;

    // Terminal Logging Helper
    function logTerminal(message: string, type: "info" | "success" | "warn" | "muted" = "info") {
      if (!terminalFeed) return;
      const line = document.createElement("div");
      let colorClass = "text-secondary";
      if (type === "success") colorClass = "text-success";
      if (type === "warn") colorClass = "text-amber-500";
      if (type === "muted") colorClass = "text-muted";

      line.className = `${colorClass}`;
      line.innerHTML = `&gt; ${message}`;
      terminalFeed.appendChild(line);

      while (terminalFeed.children.length > 5) {
        terminalFeed.removeChild(terminalFeed.firstChild!);
      }
      terminalFeed.scrollTop = terminalFeed.scrollHeight;
    }

    nameInput?.addEventListener("input", () => {
      const val = nameInput.value.trim();
      if (val) {
        logTerminal(`name_buffer_bind: "${val.substring(0, 15)}${val.length > 15 ? "..." : ""}"`, "info");
      }
    });

    emailInput?.addEventListener("input", () => {
      const val = emailInput.value.trim();
      if (val && val.includes("@")) {
        logTerminal(`socket_verify: email syntax mapped.`, "success");
      } else if (val) {
        logTerminal(`socket_check: parsing routing host...`, "muted");
      }
    });

    scopeInput?.addEventListener("input", () => {
      const val = scopeInput.value.trim();
      if (val) {
        logTerminal(`route_scope_bind: /project/${val.toLowerCase().replace(/[^a-z0-9]/g, "-")}`, "info");
      }
    });

    messageInput?.addEventListener("input", () => {
      const val = messageInput.value.trim();
      if (val.length % 20 === 0 && val.length > 0) {
        logTerminal(`payload_size_calc: ${val.length} bytes loaded`, "muted");
      }
    });

    function getFormValues() {
      return {
        name: nameInput?.value.trim() || "",
        email: emailInput?.value.trim() || "",
        scope: scopeInput?.value.trim() || "",
        message: messageInput?.value.trim() || "",
        _honeypot: honeypotInput ? honeypotInput.value : "",
      };
    }

    function triggerMailtoFallback() {
      const { name, email, scope, message } = getFormValues();
      const body = `Hello Sayan,\n\nMy name is ${name} (${email}). I am writing to discuss a project regarding "${scope}".\n\nDetails:\n${message}\n\nBest regards,\n${name}`;
      const mailtoUrl = `mailto:${emailAddr}?subject=Project Consultation: ${encodeURIComponent(scope)}&body=${encodeURIComponent(body)}`;
      logTerminal(`mailto_fallback: launching client email client.`, "warn");
      window.location.href = mailtoUrl;
    }

    contactForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const { name, email, scope, message, _honeypot } = getFormValues();
      if (!name || !email || !scope || !message) return;

      logTerminal(`payload_handshake: resolving DNS route host...`, "warn");
      contactForm.classList.add("hidden");
      loadingState?.classList.remove("hidden");
      if (loadingBar) loadingBar.style.width = "10%";
      if (loadingLog) loadingLog.textContent = "Resolving DNS routing...";

      try {
        if (loadingBar) loadingBar.style.width = "40%";
        if (loadingLog) loadingLog.textContent = "Packaging payload data...";
        logTerminal(`assembler: building JSON packaging schema...`, "info");

        const { data, error } = await actions.submitContact({ name, email, scope, message, _honeypot });

        if (loadingBar) loadingBar.style.width = "80%";
        if (loadingLog) loadingLog.textContent = "Negotiating handshake response...";
        logTerminal(`negotiator: transmitting packet (TLS 1.3)...`, "info");

        if (!error && data && data.success) {
          logTerminal(`transmitter: 200 OK successfully acknowledged.`, "success");
          if (loadingBar) loadingBar.style.width = "100%";
          setTimeout(() => {
            loadingState?.classList.add("hidden");
            successState?.classList.remove("hidden");
            contactForm.reset();
          }, 400);
        } else {
          throw new Error(error?.message || "Cockpit submit returned success: false");
        }
      } catch (err) {
        logTerminal(`transmitter_error: connection interrupted.`, "warn");
        setTimeout(() => {
          loadingState?.classList.add("hidden");
          errorState?.classList.remove("hidden");
          if (errorMessage) {
            errorMessage.textContent =
              "Network error. Sayan's Cockpit API is currently offline. Direct local email fallback is ready.";
          }
        }, 800);
      }
    });

    closeSuccessBtn?.addEventListener("click", () => {
      successState?.classList.add("hidden");
      contactForm?.classList.remove("hidden");
      logTerminal(`session_reset: listening on inputs...`, "success");
    });

    fallbackEmailBtn?.addEventListener("click", triggerMailtoFallback);

    retryBtn?.addEventListener("click", () => {
      errorState?.classList.add("hidden");
      contactForm?.classList.remove("hidden");
      logTerminal(`session_retry: listening on inputs...`, "success");
    });
  }

  function initFaqs() {
    const faqsList = document.querySelectorAll("[data-faq]");
    faqsList.forEach((el) => {
      const toggle = () => {
        const plus = el.querySelector(".faq-plus") as HTMLElement;
        const isOpen = el.classList.toggle("faq-open");
        el.setAttribute("aria-expanded", isOpen ? "true" : "false");

        if (isOpen) {
          if (plus) {
            plus.style.transform = "rotate(45deg)";
            plus.textContent = "×";
          }
        } else {
          if (plus) {
            plus.style.transform = "none";
            plus.textContent = "+";
          }
        }
      };

      el.addEventListener("click", toggle);
      el.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Enter" || (e as KeyboardEvent).key === " ") {
          e.preventDefault();
          toggle();
        }
      });
    });
  }

  document.addEventListener("astro:page-load", () => {
    initContactForm();
    initFaqs();
  });
</script>
