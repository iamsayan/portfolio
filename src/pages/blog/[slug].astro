---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getBlogPosts } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<Layout title={`${post.title} — Sayan Datta`} description={post.description}>
  <Header />
  <main id="main-content" class="py-24 relative overflow-hidden">
    <article class="pt-16 pb-28 relative z-10">
      <!-- Glow background behind post title -->
      <div
        class="absolute inset-0 opacity-[0.08] pointer-events-none"
        style="background:radial-gradient(circle at 80% 30%, var(--accent), transparent 50%)"
        aria-hidden="true"
      >
      </div>

      <div class="mx-narrow relative z-10">
        <!-- Back Button -->
        <a
          href="/blog"
          class="back-link t-mono hover:text-accent transition-colors inline-flex items-center gap-1.5 mb-8 group text-[10px] cursor-pointer"
        >
          <span class="group-hover:-translate-x-1 transition-transform" aria-hidden="true">&larr;</span>
          <span>Back to Feed</span>
        </a>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-6">
          {post.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>

        <!-- Title & Metadata -->
        <h1 class="t-heading text-balance font-extrabold leading-tight tracking-tight text-primary">
          {post.title}
        </h1>

        <div class="flex items-center gap-4 mt-6 t-mono text-xs text-muted border-b border-subtle pb-6">
          <time datetime={post.pubDate.toISOString()}>
            {post.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
          <span aria-hidden="true">·</span>
          {post.readingTime && <span>{post.readingTime} min read</span>}
        </div>

        <!-- Abstract & Coming Soon block -->
        <div class="mt-12 space-y-8">
          <div>
            <h2 class="text-xs font-mono uppercase tracking-wider text-muted font-bold mb-3">Article Abstract</h2>
            <p class="text-sm text-secondary leading-relaxed font-sans">{post.description}</p>
          </div>

          <div class="glass p-8 bg-surface border-amber-500/20 rounded-xl space-y-4">
            <div class="flex items-center gap-3">
              <span class="text-xl text-amber-500" aria-hidden="true">⚙</span>
              <h3 class="text-sm font-bold text-primary">Staged Draft — Integration in Progress</h3>
            </div>
            <p class="text-xs text-secondary leading-relaxed font-sans">
              The full publication text is currently staged as a draft. Once Sayan configures the primary API collection
              endpoints inside <code class="px-1 py-0.5 rounded bg-deep border border-subtle font-mono text-[10px]"
                >src/lib/blog.ts</code
              >, this route will automatically sync and stream content directly from Cockpit CMS.
            </p>
            <p class="text-xs text-secondary leading-relaxed font-sans">
              Stay tuned for in-depth insights into headless platforms, database query latency reductions, and modern
              JavaScript static pre-rendering pipelines.
            </p>
          </div>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  /* Back link micro-interaction */
  .back-link span {
    display: inline-block;
  }
</style>
