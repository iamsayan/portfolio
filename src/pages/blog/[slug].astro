---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getBlogPosts } from "@/lib/blog";
import { Breadcrumbs } from "astro-breadcrumbs";
import StaticComments from "@/components/StaticComments.astro";
import { Icon } from "astro-icon/components";
import { Schema } from "astro-seo-schema";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const siteUrl = Astro.site ? Astro.site.origin : "https://sayandatta.co.in";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---

<Layout
  title={`${post.title} — Sayan Datta`}
  description={post.description}
  type="article"
  articleData={{
    pubDate: post.pubDate,
    tags: post.tags,
  }}
>
  <!-- Breadcrumb JSON-LD Schema -->
  <Schema
    item={{
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": `${siteUrl}/blog`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": post.title,
          "item": canonicalURL.href
        }
      ]
    }}
  />
  <Header />
  <script>
    document.addEventListener("astro:page-load", () => {
      // 1. Reading progress indicator
      const progressBar = document.getElementById("article-scroll-bar");
      const handleScroll = () => {
        if (!progressBar) return;
        const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        progressBar.style.width = scrolled + "%";
      };

      if ((window as any).__cleanupScroll) {
        (window as any).__cleanupScroll();
      }
      
      // Initialize scroll position on load
      handleScroll();
      
      window.addEventListener("scroll", handleScroll);
      (window as any).__cleanupScroll = () => {
        window.removeEventListener("scroll", handleScroll);
      };

      // 2. Share button clipboard copy with robust fallback
      const shareBtn = document.getElementById("share-article-btn");
      if (shareBtn) {
        shareBtn.addEventListener("click", () => {
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(window.location.href)
                .then(() => updateShareLabel())
                .catch(() => fallbackCopy());
            } else {
              fallbackCopy();
            }
          } catch (e) {
            fallbackCopy();
          }

          function fallbackCopy() {
            const textarea = document.createElement("textarea");
            textarea.value = window.location.href;
            textarea.style.position = "fixed"; // prevent scrolling
            document.body.appendChild(textarea);
            textarea.select();
            try {
              document.execCommand("copy");
              updateShareLabel();
            } catch (err) {
              console.error("Fallback copy failed", err);
            }
            document.body.removeChild(textarea);
          }

          function updateShareLabel() {
            const label = shareBtn?.querySelector("span");
            if (label) {
              label.textContent = "Copied!";
              shareBtn?.classList.remove("text-secondary");
              shareBtn?.classList.add("text-success", "border-success/20", "bg-success/5");
              setTimeout(() => {
                label.textContent = "Copy Link";
                shareBtn?.classList.remove("text-success", "border-success/20", "bg-success/5");
                shareBtn?.classList.add("text-secondary");
              }, 2000);
            }
          }
        });
      }
    });
  </script>
  <main id="main-content" class="py-24 relative overflow-hidden">
    <!-- Article Scroll Progress Indicator -->
    <div id="article-scroll-bar" class="fixed top-0 left-0 h-0.5 bg-accent z-50 w-0 transition-all duration-75 ease-out" />

    <article class="pt-16 pb-28 relative z-10">
      <!-- Glow background behind post title -->
      <div
        class="absolute inset-0 opacity-[0.08] pointer-events-none"
        style="background:radial-gradient(circle at 80% 30%, var(--accent), transparent 50%)"
        aria-hidden="true"
      >
      </div>

      <div class="mx relative z-10">
        <!-- Breadcrumbs & Back to Feed parallel -->
        <div class="flex items-center justify-between flex-wrap gap-4 mb-8">
          <Breadcrumbs linkTextFormat="capitalized" customizeLinks={[{ index: "last", text: post.title }]}>
            <Fragment slot="separator">&gt;</Fragment>
          </Breadcrumbs>

          <!-- Back Button -->
          <a
            href="/blog"
            class="back-link t-mono hover:text-accent transition-colors inline-flex items-center gap-1.5 group text-[10px] cursor-pointer"
          >
            <span class="group-hover:-translate-x-1 transition-transform" aria-hidden="true">&larr;</span>
            <span>Back to Feed</span>
          </a>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-6">
          {post.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>

        <!-- Title & Metadata -->
        <h1 class="t-heading text-balance font-extrabold leading-tight tracking-tight text-primary">
          {post.title}
        </h1>

        <div class="flex items-center justify-between flex-wrap gap-4 mt-6 border-b border-subtle pb-6">
          <div class="flex items-center gap-4 t-mono text-xs text-muted">
            <time datetime={post.pubDate.toISOString()}>
              {post.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </time>
            <span aria-hidden="true">·</span>
            {post.readingTime && <span>{post.readingTime} min read</span>}
          </div>

          <button
            id="share-article-btn"
            class="inline-flex items-center gap-1.5 text-xs text-secondary hover:text-accent cursor-pointer transition-colors border border-subtle bg-surface px-2.5 py-1 rounded-lg"
            aria-label="Copy article link to clipboard"
          >
            <Icon name="ph:share-network" class="w-3.5 h-3.5" />
            <span>Copy Link</span>
          </button>
        </div>

        {
          post.comingSoon ? (
            <div class="mt-12 space-y-8">
              <div>
                <h2 class="text-xs font-mono uppercase tracking-wider text-muted font-bold mb-3">Article Abstract</h2>
                <p class="text-sm text-secondary leading-relaxed font-sans">{post.description}</p>
              </div>

              <div class="glass p-8 bg-surface border-amber-500/20 rounded-xl space-y-4">
                <div class="flex items-center gap-3">
                  <span class="text-xl text-amber-500" aria-hidden="true">
                    ⚙
                  </span>
                  <h3 class="text-sm font-bold text-primary">Staged Draft — Integration in Progress</h3>
                </div>
                <p class="text-xs text-secondary leading-relaxed font-sans">
                  The full publication text is currently staged as a draft. Once Sayan configures the primary API
                  collection endpoints inside{" "}
                  <code class="px-1 py-0.5 rounded bg-deep border border-subtle font-mono text-[10px]">
                    src/lib/blog.ts
                  </code>
                  , this route will automatically sync and stream content directly from Cockpit CMS.
                </p>
                <p class="text-xs text-secondary leading-relaxed font-sans">
                  Stay tuned for in-depth insights into headless platforms, database query latency reductions, and
                  modern JavaScript static pre-rendering pipelines.
                </p>
              </div>
            </div>
          ) : (
            <div class="prose prose-invert mt-12 text-secondary font-sans leading-relaxed">
              <div set:html={post.content} />
            </div>
          )
        }

        <!-- <StaticComments /> -->
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<!-- Prism.js client-side syntax highlighter -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"
></script>

<style>
  /* Back link micro-interaction */
  .back-link span {
    display: inline-block;
  }
</style>
