---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getBlogPosts } from "@/lib/blog";
import { Breadcrumbs } from "astro-breadcrumbs";
import StaticComments from "@/components/StaticComments.astro";
import { Icon } from "astro-icon/components";
import { Schema } from "astro-seo-schema";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const siteUrl = Astro.site ? Astro.site.origin : "https://sayandatta.co.in";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

// Get all posts to calculate Prev/Next links
const posts = await getBlogPosts();
const currentIndex = posts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
const nextPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;

// Parse H2 headings from content and inject unique IDs for TOC scrolling
let contentWithIds = post.content;
const headings = Array.from(post.content.matchAll(/<h2>(.*?)<\/h2>/g)).map((match, index) => {
  const text = match[1].replace(/<[^>]*>/g, ""); // Strip HTML tags
  const id = `heading-${index}`;
  const targetTag = match[0];
  const replacementTag = `<h2 id="${id}">${match[1]}</h2>`;
  contentWithIds = contentWithIds.replace(targetTag, replacementTag);
  return { text, id };
});
---

<Layout
  title={`${post.title} — Sayan Datta`}
  description={post.description}
  type="article"
  articleData={{
    pubDate: post.pubDate,
    tags: post.tags,
  }}
>
  <!-- Breadcrumb JSON-LD Schema -->
  <Schema
    item={{
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": `${siteUrl}/blog`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": post.title,
          "item": canonicalURL.href
        }
      ]
    }}
  />
  <Header />

  <script>
    document.addEventListener("astro:page-load", () => {
      // 1. Reading progress indicator
      const progressBar = document.getElementById("article-scroll-bar");
      const handleScroll = () => {
        if (!progressBar) return;

        // Page-based progress (guaranteed to hit 100% at the absolute bottom of the document)
        const winScroll = window.scrollY || document.documentElement.scrollTop;
        const pageHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const pageProgress = pageHeight > 0 ? (winScroll / pageHeight) * 100 : 0;

        // Article-based progress (hits 100% once the article text is fully scrolled past)
        const article = document.querySelector("article");
        let articleProgress = 0;
        if (article) {
          const rect = article.getBoundingClientRect();
          const articleHeight = rect.height;
          const winHeight = window.innerHeight;
          const startY = rect.top + window.scrollY;
          const endY = startY + articleHeight - winHeight;

          if (winScroll <= startY) {
            articleProgress = 0;
          } else if (winScroll >= endY || endY <= startY) {
            articleProgress = 100;
          } else {
            articleProgress = ((winScroll - startY) / (endY - startY)) * 100;
          }
        }

        // Combine both to ensure no gap at the bottom of the page
        const scrolled = Math.min(100, Math.max(0, pageProgress, articleProgress));
        progressBar.style.width = scrolled + "%";
      };

      if ((window as any).__cleanupScroll) {
        (window as any).__cleanupScroll();
      }
      
      // Initialize scroll position on load
      handleScroll();
      
      window.addEventListener("scroll", handleScroll);
      (window as any).__cleanupScroll = () => {
        window.removeEventListener("scroll", handleScroll);
      };

      // 2. Share button clipboard copy with robust fallback
      const shareBtn = document.getElementById("share-article-btn");
      if (shareBtn) {
        shareBtn.addEventListener("click", () => {
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(window.location.href)
                .then(() => updateShareLabel())
                .catch(() => fallbackCopy());
            } else {
              fallbackCopy();
            }
          } catch (e) {
            fallbackCopy();
          }

          function fallbackCopy() {
            const textarea = document.createElement("textarea");
            textarea.value = window.location.href;
            textarea.style.position = "fixed"; // prevent scrolling
            document.body.appendChild(textarea);
            textarea.select();
            try {
              document.execCommand("copy");
              updateShareLabel();
            } catch (err) {
              console.error("Fallback copy failed", err);
            }
            document.body.removeChild(textarea);
          }

          function updateShareLabel() {
            const label = shareBtn?.querySelector("span");
            if (label) {
              label.textContent = "Copied!";
              shareBtn?.classList.remove("text-secondary");
              shareBtn?.classList.add("text-success", "border-success/20", "bg-success/5");
              setTimeout(() => {
                label.textContent = "Copy Link";
                shareBtn?.classList.remove("text-success", "border-success/20", "bg-success/5");
                shareBtn?.classList.add("text-secondary");
              }, 2000);
            }
          }
        });
      }

      // 3. Table of Contents Intersection Observer
      const tocLinks = document.querySelectorAll(".toc-link");
      const tocHeadings = document.querySelectorAll("article h2");

      if (tocLinks.length > 0 && tocHeadings.length > 0) {
        const observerOptions = {
          root: null,
          rootMargin: "0px 0px -65% 0px", // triggers when heading is in top portion
          threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.getAttribute("id");
              tocLinks.forEach((link) => {
                if (link.getAttribute("data-target") === id) {
                  link.classList.add("text-accent", "font-semibold");
                  link.classList.remove("text-secondary");
                } else {
                  link.classList.remove("text-accent", "font-semibold");
                  link.classList.add("text-secondary");
                }
              });
            }
          });
        }, observerOptions);

        tocHeadings.forEach((heading) => observer.observe(heading));

        if ((window as any).__cleanupTOC) {
          (window as any).__cleanupTOC();
        }
        (window as any).__cleanupTOC = () => {
          tocHeadings.forEach((heading) => observer.unobserve(heading));
        };
      }

      // 4. Interactive "Copy Code" Overlay Buttons for syntax blocks
      const codeBlocks = document.querySelectorAll("pre");
      codeBlocks.forEach((block) => {
        if (block.querySelector(".copy-code-btn")) return;
        block.classList.add("group");

        const btn = document.createElement("button");
        btn.className = "copy-code-btn absolute top-3.5 right-4 z-10 px-2 py-1 rounded bg-raised/80 border border-subtle text-[10px] text-secondary hover:text-accent opacity-0 group-hover:opacity-100 transition-all duration-200 cursor-pointer flex items-center gap-1.5";
        btn.innerHTML = `<svg class="w-3 h-3" viewBox="0 0 256 256" fill="currentColor"><path d="M216 32H88a8 8 0 0 0-8 8v40H40a8 8 0 0 0-8 8v128a8 8 0 0 0 8 8h128a8 8 0 0 0 8-8v-40h40a8 8 0 0 0 8-8V40a8 8 0 0 0-8-8m-56 176H48V96h112Zm48-48h-32V88a8 8 0 0 0-8-8H96V48h112Z"/></svg><span>Copy</span>`;

        btn.addEventListener("click", () => {
          const code = block.querySelector("code")?.innerText || "";
          navigator.clipboard.writeText(code).then(() => {
            const span = btn.querySelector("span");
            if (span) {
              span.textContent = "Copied!";
              btn.classList.add("text-success", "border-success/30");
              setTimeout(() => {
                span.textContent = "Copy";
                btn.classList.remove("text-success", "border-success/30");
              }, 2000);
            }
          }).catch(() => {
            // Fallback for non-secure contexts
            const textarea = document.createElement("textarea");
            textarea.value = code;
            textarea.style.position = "fixed";
            document.body.appendChild(textarea);
            textarea.select();
            try {
              document.execCommand("copy");
              const span = btn.querySelector("span");
              if (span) {
                span.textContent = "Copied!";
                btn.classList.add("text-success", "border-success/30");
                setTimeout(() => {
                  span.textContent = "Copy";
                  btn.classList.remove("text-success", "border-success/30");
                }, 2000);
              }
            } catch (err) {
              console.error("Code block fallback copy failed", err);
            }
            document.body.removeChild(textarea);
          });
        });

        block.appendChild(btn);
      });
    });
  </script>

  <main id="main-content" class="py-24 relative overflow-hidden">
    <!-- Article Scroll Progress Indicator -->
    <div id="article-scroll-bar" class="fixed top-0 left-0 h-0.5 bg-accent z-50 w-0 transition-all duration-75 ease-out" />

    <article class="pt-16 pb-28 relative z-10">
      <!-- Glow background behind post title -->
      <div
        class="absolute inset-0 opacity-[0.08] pointer-events-none"
        style="background:radial-gradient(circle at 80% 30%, var(--accent), transparent 50%)"
        aria-hidden="true"
      >
      </div>

      <div class="mx relative z-10">
        <!-- Breadcrumbs & Back to Feed parallel -->
        <div class="flex items-center justify-between flex-wrap gap-4 mb-8">
          <Breadcrumbs linkTextFormat="capitalized" customizeLinks={[{ index: "last", text: post.title }]}>
            <Fragment slot="separator">&gt;</Fragment>
          </Breadcrumbs>

          <!-- Back Button -->
          <a
            href="/blog"
            class="back-link t-mono hover:text-accent transition-colors inline-flex items-center gap-1.5 group text-[10px] cursor-pointer"
          >
            <span class="group-hover:-translate-x-1 transition-transform" aria-hidden="true">&larr;</span>
            <span>Back to Feed</span>
          </a>
        </div>

        <!-- 2-Column Professional Layout Grid -->
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          
          <!-- Left Main Content Column -->
          <div class="lg:col-span-9 min-w-0">
            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
              {post.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>

            <!-- Title -->
            <h1 class="t-heading text-balance font-extrabold leading-tight tracking-tight text-primary">
              {post.title}
            </h1>

            <!-- Metadata Panel -->
            <div class="flex items-center justify-between flex-wrap gap-4 mt-6 border-b border-subtle pb-6">
              <div class="flex items-center gap-4 t-mono text-xs text-muted">
                <time datetime={post.pubDate.toISOString()}>
                  {post.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                <span aria-hidden="true">·</span>
                {post.readingTime && <span>{post.readingTime} min read</span>}
              </div>

              <button
                id="share-article-btn"
                class="inline-flex items-center gap-1.5 text-xs text-secondary hover:text-accent cursor-pointer transition-colors border border-subtle bg-surface px-2.5 py-1 rounded-lg"
                aria-label="Copy article link to clipboard"
              >
                <Icon name="ph:share-network" class="w-3.5 h-3.5" />
                <span>Copy Link</span>
              </button>
            </div>

            <!-- Post Body -->
            {
              post.comingSoon ? (
                <div class="mt-12 space-y-8">
                  <div>
                    <h2 class="text-xs font-mono uppercase tracking-wider text-muted font-bold mb-3">Article Abstract</h2>
                    <p class="text-sm text-secondary leading-relaxed font-sans">{post.description}</p>
                  </div>

                  <div class="glass p-8 bg-surface border-amber-500/20 rounded-xl space-y-4">
                    <div class="flex items-center gap-3">
                      <span class="text-xl text-amber-500" aria-hidden="true">⚙</span>
                      <h3 class="text-sm font-bold text-primary">Staged Draft — Integration in Progress</h3>
                    </div>
                    <p class="text-xs text-secondary leading-relaxed font-sans">
                      The full publication text is currently staged as a draft. Once Sayan configures the primary API
                      collection endpoints inside{" "}
                      <code class="px-1 py-0.5 rounded bg-deep border border-subtle font-mono text-[10px]">
                        src/lib/blog.ts
                      </code>
                      , this route will automatically sync and stream content directly from Cockpit CMS.
                    </p>
                    <p class="text-xs text-secondary leading-relaxed font-sans">
                      Stay tuned for in-depth insights into headless platforms, database query latency reductions, and
                      modern JavaScript static pre-rendering pipelines.
                    </p>
                  </div>
                </div>
              ) : (
                <div class="prose prose-invert mt-12 text-secondary font-sans leading-relaxed">
                  <div set:html={contentWithIds} />
                </div>
              )
            }

            <!-- Prev/Next Navigation links -->
            <div class="grid sm:grid-cols-2 gap-4 border-t border-subtle pt-10 mt-16">
              {prevPost ? (
                <a
                  href={`/blog/${prevPost.id}`}
                  class="glass p-5 rounded-xl border border-subtle hover:border-accent/40 bg-surface/50 group transition-all duration-300 flex flex-col text-left cursor-pointer"
                >
                  <span class="text-[10px] font-mono text-muted uppercase tracking-wider mb-2 flex items-center gap-1">
                    &larr; Previous Article
                  </span>
                  <span class="text-sm font-semibold text-primary group-hover:text-accent transition-colors line-clamp-2">
                    {prevPost.title}
                  </span>
                </a>
              ) : (
                <div class="glass p-5 rounded-xl border border-dashed border-subtle bg-surface/10 flex items-center justify-center opacity-40 text-xs text-muted select-none">
                  No older publications
                </div>
              )}

              {nextPost ? (
                <a
                  href={`/blog/${nextPost.id}`}
                  class="glass p-5 rounded-xl border border-subtle hover:border-accent/40 bg-surface/50 group transition-all duration-300 flex flex-col text-right items-end cursor-pointer"
                >
                  <span class="text-[10px] font-mono text-muted uppercase tracking-wider mb-2 flex items-center gap-1">
                    Next Article &rarr;
                  </span>
                  <span class="text-sm font-semibold text-primary group-hover:text-accent transition-colors line-clamp-2">
                    {nextPost.title}
                  </span>
                </a>
              ) : (
                <div class="glass p-5 rounded-xl border border-dashed border-subtle bg-surface/10 flex items-center justify-center opacity-40 text-xs text-muted select-none">
                  No newer publications
                </div>
              )}
            </div>

            <!-- Discussion & Comments Section -->
            <div class="border-t border-subtle mt-16 pt-10">
              <h3 class="font-display text-lg font-bold text-primary mb-6 flex items-center gap-2">
                <Icon name="ph:chat-circle" class="w-5 h-5 text-accent" />
                <span>Discussion & Feedback</span>
              </h3>
              <StaticComments />
            </div>
          </div>

          <!-- Right Sidebar: Table of Contents & Bio (sticky) -->
          <aside class="lg:col-span-3 sticky top-24 self-start hidden lg:block space-y-6">
            {headings.length > 0 && (
              <div class="glass p-5 bg-surface border-subtle rounded-xl space-y-4">
                <h4 class="text-xs font-mono uppercase tracking-wider text-muted font-bold flex items-center gap-2">
                  <Icon name="ph:list-bullets" class="w-4 h-4 text-accent" />
                  <span>Table of Contents</span>
                </h4>
                <nav class="toc-nav">
                  <ul class="space-y-3.5 text-xs text-secondary">
                    {headings.map((h) => (
                      <li>
                        <a
                          href={`#${h.id}`}
                          class="toc-link hover:text-accent transition-colors block leading-relaxed relative pl-3.5 before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:rounded-full before:bg-accent/20 hover:before:bg-accent before:transition-colors"
                          data-target={h.id}
                        >
                          {h.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>
            )}
            
            <!-- Author Card -->
            <div class="glass p-5 bg-surface border-subtle rounded-xl space-y-3.5">
              <h4 class="text-xs font-mono uppercase tracking-wider text-muted font-bold">Written By</h4>
              <div class="flex items-center gap-3">
                <img
                  src="https://github.com/iamsayan.png"
                  alt="Sayan Datta"
                  class="w-10 h-10 rounded-lg object-cover border border-subtle"
                  width="40"
                  height="40"
                  loading="lazy"
                />
                <div>
                  <h5 class="text-xs font-bold text-primary">Sayan Datta</h5>
                  <p class="text-[10px] text-muted font-mono mt-0.5">Senior Developer</p>
                </div>
              </div>
              <p class="text-[11px] text-secondary leading-relaxed font-sans">
                Full-stack engineer specializing in WooCommerce plugins, API scale, and React headless platforms.
              </p>
            </div>

            <!-- Git Document Metadata -->
            <div class="glass p-5 bg-surface border-subtle rounded-xl space-y-3.5">
              <h4 class="text-xs font-mono uppercase tracking-wider text-muted font-bold flex items-center gap-2">
                <Icon name="ph:git-branch" class="w-4 h-4 text-accent" />
                <span>Document Metadata</span>
              </h4>
              <div class="space-y-2.5 font-mono text-[10px] text-secondary">
                <div class="flex items-center justify-between border-b border-subtle/50 pb-1.5">
                  <span class="text-muted">Repository</span>
                  <span>iamsayan/portfolio</span>
                </div>
                <div class="flex items-center justify-between border-b border-subtle/50 pb-1.5">
                  <span class="text-muted">Branch</span>
                  <span class="text-accent flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
                    main
                  </span>
                </div>
                <div class="flex items-center justify-between border-b border-subtle/50 pb-1.5">
                  <span class="text-muted">Commit ID</span>
                  <span class="hover:text-accent transition-colors font-semibold">f43f5e2</span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-muted">Status</span>
                  <span class="text-success uppercase font-bold text-[9px] px-1.5 py-0.5 rounded bg-success/10 border border-success/20">
                    Committed
                  </span>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<!-- Prism.js client-side syntax highlighter -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"
></script>

<style>
  /* Back link micro-interaction */
  .back-link span {
    display: inline-block;
  }
</style>
