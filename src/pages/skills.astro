---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const categories = [
  {
    name: "Frontend Stack",
    desc: "Crafting modular, high-speed user interfaces that are fast, accessible, and structured.",
    skills: [
      { name: "Next.js / React", pct: "95%", context: "Primary production framework. React Server Components, App Router, middleware routing, and dynamic data streaming." },
      { name: "TypeScript", pct: "90%", context: "Type safety across the stack. Generics, utility type mapping, strict configurations." },
      { name: "Tailwind CSS", pct: "92%", context: "Styling layout designs, utility structures, theme definitions, and custom Vite configs." },
      { name: "Vue.js", pct: "70%", context: "Single File Components, Vue Router, Pinia client state management." },
    ],
  },
  {
    name: "Backend Architecture",
    desc: "Designing secure, maintainable server environments that scale to real workloads.",
    skills: [
      { name: "PHP / WordPress", pct: "95%", context: "Custom plugins, database actions, headless WordPress API feeds. 8+ years deep." },
      { name: "Node.js", pct: "80%", context: "Vite dev servers, Express APIs, custom route handlers, request validation scripts." },
      { name: "Laravel", pct: "78%", context: "Eloquent ORM, artisan script command pipelines, database seed configurations." },
      { name: "Python", pct: "65%", context: "Script automation, JSON data processing modules, API endpoints." },
    ],
  },
  {
    name: "DevOps & Databases",
    desc: "Infrastructure pipelines, version controls, and query indexing setups.",
    skills: [
      { name: "MySQL / PostgreSQL", pct: "82%", context: "Schema optimization, indexing, foreign keys, complex transaction management." },
      { name: "REST API / GraphQL", pct: "88%", context: "Secure API design pattern structures, WPGraphQL integrations, Apollo client feeds." },
      { name: "Git / CI-CD", pct: "85%", context: "GitHub Actions runner workflows, automated unit checking, zero-downtime Vercel/Docker deploys." },
      { name: "Docker / Linux", pct: "75%", context: "Multi-stage Dockerfile configurations, Docker Compose orchestration, Nginx reverse proxy routes." },
    ],
  },
];

const additional = "JavaScript HTML5 CSS3 jQuery AJAX Bootstrap WooCommerce Redis Nginx Vercel Gutenberg".split(" ");
---

<Layout title="Skills — Sayan Datta" description="Comprehensive overview of Sayan Datta's development stack, tools, languages, and technical competencies.">
  <Header />
  <main>
    <!-- Header Hero -->
    <section class="pt-32 pb-20 relative">
      <div class="mx">
        <p class="t-mono text-[var(--accent)]">Tech stack</p>
        <h1 class="t-heading mt-4 reveal r1">Skills &amp; Toolkit.</h1>
        <p class="t-body mt-6 max-w-2xl reveal r2">
          A list of the technologies and languages I work with on daily production builds, complete with details on my actual hands-on application.
        </p>
      </div>
    </section>

    <!-- Skills Dashboard Grid -->
    <section class="pb-28">
      <div class="mx space-y-20">
        {categories.map((cat, ci) => (
          <div class="reveal">
            <!-- Category Header -->
            <div class="mb-8 border-b border-[var(--border-subtle)] pb-4 flex items-center justify-between">
              <div>
                <span class="text-xs font-mono text-[var(--accent)] font-bold">0{ci + 1} &mdash; CATEGORY</span>
                <h2 class="text-xl font-bold text-[var(--text-primary)] mt-1">{cat.name}</h2>
                <p class="text-sm text-[var(--text-secondary)] mt-1">{cat.desc}</p>
              </div>
            </div>

            <!-- Skills Cards Grid -->
            <div class="grid sm:grid-cols-2 gap-6">
              {cat.skills.map(s => (
                <div class="glass p-6 bg-[var(--bg-surface)] border-[var(--border-subtle)] hover:border-[var(--accent-glow-strong)] transition-all">
                  <div class="flex justify-between items-baseline mb-3">
                    <span class="text-sm font-bold text-[var(--text-primary)]">{s.name}</span>
                    <span class="text-xs font-mono text-[var(--accent)] font-semibold">{s.pct}</span>
                  </div>
                  <!-- Laser Glow Progress Bar -->
                  <div class="h-1.5 w-full bg-[var(--bg-deep)] rounded-full overflow-hidden border border-[var(--border-subtle)]">
                    <div 
                      class="h-full rounded-full bg-gradient-to-r from-[var(--accent)] to-[var(--accent-bright)] shadow-[0_0_8px_var(--accent)]" 
                      style={`width: ${s.pct}`}
                    ></div>
                  </div>
                  <p class="text-xs text-[var(--text-secondary)] mt-4 leading-relaxed font-sans">{s.context}</p>
                </div>
              ))}
            </div>
          </div>
        ))}

        <!-- Additional Secondary Technologies -->
        <div class="glass p-8 bg-[var(--bg-surface)] border-[var(--border-subtle)] reveal">
          <p class="t-mono text-[var(--accent)] mb-4 text-xs font-bold">Secondary Stack &amp; Libraries</p>
          <div class="flex flex-wrap gap-2.5">
            {additional.map(t => (
              <span class="tag hover:scale-105 transition-transform duration-200">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  var observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
      }
    });
  }, { threshold: 0.05 });
  
  document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
</script>
