---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PageHero from "@/components/PageHero.astro";

const services = [
  {
    id: "react",
    number: "01",
    label: "Next.js & React",
    title: "React & Next.js Engineering",
    color: "blue",
    summary:
      "Dynamic, decoupled applications using React, Next.js, and Astro. Focused on React Server Components, server actions, layout stability, and zero-JS static sites where they fit.",
    proof: [
      { label: "Lighthouse score", value: "98+" },
      { label: "Accessibility", value: "WCAG AA" },
    ],
    capabilities: [
      {
        title: "Render Optimization",
        body:
          "Choosing static generation, server-side rendering, and React Server Components per route. Optimizing FCP, LCP, and Cumulative Layout Shift against Core Web Vitals thresholds.",
      },
      {
        title: "Type-Safe Client States",
        body:
          "Strict TypeScript for every prop, fetch interface, and reducer. Type errors caught at compile time, not in production runtime.",
      },
      {
        title: "Interactive Micro-Animations",
        body:
          "Subtle hover feedback, smooth tab transitions, and loading states without pulling in heavy animation libraries or shipping megabytes of JS.",
      },
      {
        title: "Semantic HTML & WCAG Compliance",
        body:
          "Valid ARIA roles, logical keyboard focus rings, named landmarks, and verified screen-reader readability on every interactive surface.",
      },
    ],
    blueprint: {
      heading: "Next.js Routing Blueprint",
      rows: [
        { dot: "app/page.tsx", meta: "Server Component", pills: ["async/await fetch", "Next.js App Router"] },
        { dot: "hooks/useUPIGateway.ts", meta: "Custom Hook", pills: ["useState / useEffect", "React state hooks"] },
      ],
    },
  },
  {
    id: "backend",
    number: "02",
    label: "Backend",
    title: "Backend Architecture",
    color: "emerald",
    summary:
      "Secure APIs, relational schemas, and microservice topologies built with PHP/Laravel and Node.js. Query optimization, queue pipelines, and automated deployments included.",
    proof: [
      { label: "Primary stack", value: "Laravel · Node" },
      { label: "Container", value: "Docker-ready" },
    ],
    capabilities: [
      {
        title: "REST & GraphQL Schema Design",
        body:
          "Modular resource schemas with secure query authorization, payload validation, and structured responses for headless consumers.",
      },
      {
        title: "Caching & Query Tuning",
        body:
          "Redis cache pipelines for read-heavy endpoints, composite indexes for hot queries, and query plan analysis via EXPLAIN to keep p95 latency predictable.",
      },
      {
        title: "Security Hardening",
        body:
          "CORS rules, rate limiting, JWT/API token rotation, and input sanitization to block the OWASP top 10 at the application boundary.",
      },
      {
        title: "Background Pipelines & Queues",
        body:
          "Asynchronous job structures for webhooks, third-party sync, and heavy workloads. Action Scheduler for WordPress, Laravel Queues for PHP, BullMQ for Node.",
      },
    ],
    blueprint: {
      heading: "Request Architecture",
      rows: [
        { dot: "Client Req", meta: "Origin", pills: [], highlight: false },
        { dot: "API Gateway", meta: "Validate", pills: [], highlight: true },
        { dot: "Redis Cache", meta: "Lookup", pills: [], highlight: false },
        { dot: "DB Core", meta: "Persist", pills: [], highlight: false },
      ],
    },
  },
  {
    id: "wordpress",
    number: "03",
    label: "WordPress",
    title: "WordPress Engineering",
    color: "amber",
    summary:
      "Custom plugins, headless GraphQL setups, and optimization for enterprise traffic. Active maintainer of plugins with 27,000+ combined active installs.",
    proof: [
      { label: "Active installs", value: "27,000+" },
      { label: "Code standard", value: "PHP · PSR-12" },
    ],
    capabilities: [
      {
        title: "Custom Plugin Architecture",
        body:
          "Hook-based plugin structures that avoid slowing admin panels or polluting public database queries. PSR-4 autoloading and strict sanitization at every input boundary.",
      },
      {
        title: "Headless CMS with WPGraphQL",
        body:
          "WordPress content exposed through GraphQL and consumed by static builders (Next.js, Astro) for sub-second page loads on the public surface.",
      },
      {
        title: "WooCommerce Integrations",
        body:
          "Custom shipping rules, subscription handlers, checkout modifications, and payment gateway extensions that survive the WooCommerce core update cycle.",
      },
      {
        title: "Database & Index Optimizations",
        body:
          "Auditing the wp_options table, indexing custom meta keys, and using transients to prevent query fanout on high-traffic admin screens.",
      },
    ],
    blueprint: {
      heading: "Checkout Trigger Pipeline",
      rows: [
        { dot: "woocommerce_payment_complete", meta: "Action Hook", pills: [], highlight: false },
        { dot: "Send UPI Webhook", meta: "Webhook Out", pills: [], highlight: true },
        { dot: "Action Scheduler", meta: "Queue", pills: [], highlight: false },
      ],
    },
  },
  {
    id: "responsive",
    number: "04",
    label: "Layout Design",
    title: "Mobile-First UI Design",
    color: "rose",
    summary:
      "Responsive grid architectures from 320px up. Logical layout reflows, fluid typography, container queries, and cross-browser visual regression testing.",
    proof: [
      { label: "Approach", value: "Container queries" },
      { label: "Breakpoints", value: "5 tested" },
    ],
    capabilities: [
      {
        title: "Fluid Typography",
        body:
          "CSS variables and clamp() mappings that scale headings from extra-bold desktop displays down to readable phone sizes without breakpoint jumps.",
      },
      {
        title: "Accessibility-First Markup",
        body:
          "Screen reader compatibility, semantic HTML, contrast ratios meeting WCAG AA, and visible focus outlines on every interactive element.",
      },
      {
        title: "Container Queries & Micro-Breakpoints",
        body:
          "Replacing viewport media queries with @container where it makes sense, so components adapt to their parent rather than the page width.",
      },
      {
        title: "Cross-Browser Visual Regression",
        body:
          "Visual diffs across Blink (Chrome/Edge), WebKit (Safari), and Gecko (Firefox) on real devices before shipping a layout change.",
      },
    ],
    blueprint: {
      heading: "Container Reflow Blueprint",
      rows: [
        { dot: "@container (min-width: 600px)", meta: "2-Column Grid Flow", pills: [], highlight: false },
        { dot: "@container (max-width: 599px)", meta: "Block Stacked Flow", pills: [], highlight: false },
      ],
    },
  },
  {
    id: "ai",
    number: "05",
    label: "AI & Agentic Systems",
    title: "AI Integration & Agentic Systems",
    color: "purple",
    summary:
      "Autonomous agent networks, custom LLM integrations, and semantic search pipelines. Orchestrating Gemini, Claude, DeepSeek, Cohere Command, and open-source code models.",
    proof: [
      { label: "Primary APIs", value: "Gemini · Claude" },
      { label: "Local models", value: "DeepSeek · Llama" },
    ],
    capabilities: [
      {
        title: "Autonomous Agent Workflows",
        body:
          "Loop-driven, self-correcting agent chains that orchestrate multi-step actions — API calls, code edits, commits — without manual intervention per step.",
      },
      {
        title: "RAG Pipelines",
        body:
          "Connecting Gemini, Claude, DeepSeek, or Cohere Command to custom databases and knowledge bases via vector embeddings and chunked context windows.",
      },
      {
        title: "Streaming UI Token Handlers",
        body:
          "Server-Sent Events to render chunked LLM outputs into the DOM as they arrive, so the user sees the first token in under a second instead of waiting on a full response.",
      },
      {
        title: "Semantic Cache Routing",
        body:
          "Gateway middleware that checks vector similarity for repeated queries before re-running inference, cutting token spend without changing visible behavior.",
      },
    ],
    blueprint: {
      heading: "Agent Reasoning Loop",
      rows: [
        { dot: "User Query", meta: "Input", pills: [], highlight: false },
        { dot: "LLM Planner", meta: "Decide", pills: [], highlight: true },
        { dot: "Tool Execution", meta: "Act", pills: [], highlight: false },
      ],
    },
  },
];

// Color tokens for each service — uses design-system hover-glow classes
const colorMap: Record<string, { label: string; dot: string; arrow: string; pill: string; pillBg: string; pillBorder: string }> = {
  blue: {
    label: "text-blue-500",
    dot: "bg-blue-500",
    arrow: "text-blue-500",
    pill: "text-blue-400",
    pillBg: "bg-blue-500/10",
    pillBorder: "border-blue-500/20",
  },
  emerald: {
    label: "text-emerald-500",
    dot: "bg-emerald-500",
    arrow: "text-emerald-500",
    pill: "text-emerald-400",
    pillBg: "bg-emerald-500/10",
    pillBorder: "border-emerald-500/20",
  },
  amber: {
    label: "text-amber-500",
    dot: "bg-amber-500",
    arrow: "text-amber-500",
    pill: "text-amber-400",
    pillBg: "bg-amber-500/10",
    pillBorder: "border-amber-500/20",
  },
  rose: {
    label: "text-rose-500",
    dot: "bg-rose-500",
    arrow: "text-rose-500",
    pill: "text-rose-400",
    pillBg: "bg-rose-500/10",
    pillBorder: "border-rose-500/20",
  },
  purple: {
    label: "text-purple-500",
    dot: "bg-purple-500",
    arrow: "text-purple-500",
    pill: "text-purple-400",
    pillBg: "bg-purple-500/10",
    pillBorder: "border-purple-500/20",
  },
};

const glowMap: Record<string, string> = {
  blue: "hover-glow-blue",
  emerald: "hover-glow-emerald",
  amber: "hover-glow-amber",
  rose: "hover-glow-rose",
  purple: "hover-glow-purple",
};
---

<Layout
  title="Services | Custom Plugins & WooCommerce Solutions"
  description="Full-stack development consulting — WooCommerce checkout scaling, payment gateway integrations, custom APIs, and headless site architecture."
>
  <Header />
  <main id="main-content" class="py-24 relative overflow-x-clip">
    <PageHero
      badge="Engineering Capabilities"
      description="Five practice areas I take on as a contractor. Each ships with code reviews, automated tests, and documentation. No retainers, no advisory decks."
    >
      <Fragment slot="title">Services &amp; <span class="t-accent">architecture.</span></Fragment>
    </PageHero>

    <!-- Services Detail Grids -->
    <section class="pb-28 relative z-10">
      <div class="mx grid lg:grid-cols-12 gap-10 items-start">
        <!-- Left: Service Selector Tabs (4 cols) -->
        <div class="lg:col-span-4 lg:sticky lg:top-24 z-20">
          <div class="flex lg:flex-col overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0 gap-3.5 scrollbar-none snap-x snap-mandatory">
            {
              services.map((svc, idx) => {
                const c = colorMap[svc.color];
                return (
                  <button
                    data-tab={svc.id}
                    data-color={svc.color}
                    class={`tab-btn w-[280px] lg:w-full flex-shrink-0 snap-start text-left glass p-5 bg-surface border-subtle transition-all duration-300 relative group cursor-pointer ${
                      idx === 0 ? `active active-${svc.color}` : ""
                    }`}
                  >
                    <div class="flex items-center gap-3">
                      <span class={`w-1.5 h-1.5 rounded-full ${c.dot} opacity-0 group-[.active]:opacity-100 transition-opacity`} />
                      <span class={`text-[10px] font-mono tracking-wider ${c.label} uppercase font-bold`}>
                        {svc.number}
                      </span>
                    </div>
                    <h3 class="font-bold text-md text-primary mt-2 group-[.active]:text-accent transition-colors">
                      {svc.label}
                    </h3>
                    <p class="text-[11px] text-secondary mt-1 line-clamp-1 group-[.active]:text-primary transition-colors">
                      {svc.title}
                    </p>
                  </button>
                );
              })
            }
          </div>
        </div>

        <!-- Right: Active Service Details Panel (8 cols) -->
        <div class="lg:col-span-8 relative min-h-[500px]">
          {
            services.map((svc, idx) => {
              const c = colorMap[svc.color];
              const glow = glowMap[svc.color];
              return (
                <div
                  id={`panel-${svc.id}`}
                  class={`tab-panel transition-all duration-300 ${
                    idx === 0 ? "grid gap-6 opacity-100" : "hidden gap-6 opacity-0"
                  }`}
                >
                  {/* Summary Card */}
                  <div class="glass p-8 bg-surface border-subtle space-y-4">
                    <span
                      class={`inline-block text-xs font-mono ${c.label} uppercase tracking-wider ${c.pillBg} px-3 py-1 rounded-md border ${c.pillBorder}`}
                    >
                      {svc.number} &mdash; {svc.label.toUpperCase()}
                    </span>
                    <h2 class="t-title text-2xl font-bold text-primary">{svc.title}</h2>
                    <p class="t-body text-secondary leading-relaxed font-sans">{svc.summary}</p>

                    <div class="grid grid-cols-2 gap-4 pt-3">
                      {svc.proof.map((p) => (
                        <div class="border border-subtle p-4 rounded-lg bg-surface/50">
                          <p class="text-[10px] font-mono text-muted uppercase">{p.label}</p>
                          <p class="text-sm font-bold text-success mt-1">{p.value}</p>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Capabilities Card */}
                  <div class={`glass ${glow} p-8 bg-surface border-subtle`}>
                    <h3 class="text-md font-bold text-primary mb-4">What I actually do here</h3>
                    <div class="space-y-5">
                      {svc.capabilities.map((cap) => (
                        <div class="flex gap-3 border-l-2 border-subtle pl-4 hover:border-accent transition-colors">
                          <div>
                            <h4 class="text-sm font-bold text-primary">{cap.title}</h4>
                            <p class="text-xs text-secondary mt-1.5 leading-relaxed font-sans">{cap.body}</p>
                          </div>
                        </div>
                      ))}
                    </div>

                    {/* Blueprint Mock Widget */}
                    <div class="mt-8 border border-subtle rounded-lg bg-deep p-5 space-y-3">
                      <p class="text-[10px] font-mono text-muted">{svc.blueprint.heading.toUpperCase()}</p>
                      {svc.blueprint.rows.map((row) => (
                        <div class="border border-dashed border-strong rounded p-3.5 flex flex-col md:flex-row gap-3 items-start md:items-center justify-between">
                          <div class="flex items-center gap-3 min-w-0">
                            <span class={`w-2.5 h-2.5 rounded-full ${c.dot} flex-shrink-0`} />
                            <div class="min-w-0">
                              <p class="text-xs font-mono text-primary truncate">{row.dot}</p>
                              <p class={`text-[9px] font-mono ${c.label} mt-0.5`}>{row.meta}</p>
                            </div>
                          </div>
                          {row.pills && row.pills.length > 0 && (
                            <div class="flex gap-2 flex-wrap">
                              {row.pills.map((pill, pi) => (
                                <span
                                  class={`px-2 py-0.5 border text-[9px] font-mono rounded ${
                                    pi === row.pills.length - 1
                                      ? `${c.pillBorder} ${c.pill} ${c.pillBg}`
                                      : "border-strong text-secondary"
                                  }`}
                                >
                                  {pill}
                                </span>
                              ))}
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Tab Button Active Glow Styling */
  .tab-btn.active-blue {
    border-color: rgba(59, 130, 246, 0.3) !important;
    background: rgba(59, 130, 246, 0.05) !important;
    box-shadow: 0 0 15px rgba(59, 130, 246, 0.06) !important;
  }
  .tab-btn.active-emerald {
    border-color: rgba(16, 185, 129, 0.3) !important;
    background: rgba(16, 185, 129, 0.05) !important;
    box-shadow: 0 0 15px rgba(16, 185, 129, 0.06) !important;
  }
  .tab-btn.active-amber {
    border-color: rgba(245, 158, 11, 0.3) !important;
    background: rgba(245, 158, 11, 0.05) !important;
    box-shadow: 0 0 15px rgba(245, 158, 11, 0.06) !important;
  }
  .tab-btn.active-rose {
    border-color: rgba(244, 63, 94, 0.3) !important;
    background: rgba(244, 63, 94, 0.05) !important;
    box-shadow: 0 0 15px rgba(244, 63, 94, 0.06) !important;
  }
  .tab-btn.active-purple {
    border-color: rgba(168, 85, 247, 0.3) !important;
    background: rgba(168, 85, 247, 0.05) !important;
    box-shadow: 0 0 15px rgba(168, 85, 247, 0.06) !important;
  }

  /* Hide scrollbar for WebKit browsers */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-none {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<script>
  var buttons = document.querySelectorAll(".tab-btn");
  var panels = document.querySelectorAll(".tab-panel");

  buttons.forEach(function(btn) {
    btn.addEventListener("click", function() {
      // Remove active states from all buttons
      buttons.forEach(function(b) {
        b.classList.remove("active");
        var color = b.getAttribute("data-color");
        if (color) {
          b.classList.remove("active-" + color);
        }
      });

      // Add active state to clicked button
      btn.classList.add("active");
      var activeColor = btn.getAttribute("data-color");
      if (activeColor) {
        btn.classList.add("active-" + activeColor);
      }

      // Hide all panels
      panels.forEach(function(panel) {
        panel.classList.add("hidden");
        panel.classList.remove("grid");
      });

      // Show matching panel
      var targetId = "panel-" + btn.getAttribute("data-tab");
      var targetPanel = document.getElementById(targetId);
      if (targetPanel) {
        targetPanel.classList.remove("hidden");
        targetPanel.classList.add("grid");

        // Quick subtle entry animation
        (targetPanel as HTMLElement).style.opacity = "0";
        (targetPanel as HTMLElement).style.transform = "translateY(5px)";
        setTimeout(function() {
          (targetPanel as HTMLElement).style.opacity = "1";
          (targetPanel as HTMLElement).style.transform = "translateY(0px)";
        }, 50);
      }
    });
  });
</script>

