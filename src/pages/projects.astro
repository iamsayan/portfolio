---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getProjectsPage, isTeamContribution } from "@/lib/data";
import { Icon } from "astro-icon/components";
import PageHero from "@/components/PageHero.astro";

const projectsPage = await getProjectsPage();
const featured = projectsPage.featuredProjects;
const rest = projectsPage.projects;
const allProjects = [...featured, ...rest];

// Filter tabs reflect actual data categories, not invented buckets
type FilterBucket = { id: string; label: string; count: number };
const filterBuckets: FilterBucket[] = [
  { id: "all", label: "All Projects", count: allProjects.length },
  {
    id: "wordpress",
    label: "WordPress Plugins",
    count: allProjects.filter((p) => p.category === "wordpress").length,
  },
  {
    id: "packages",
    label: "Libraries / Packages",
    count: allProjects.filter((p) => p.category === "packages").length,
  },
  {
    id: "fullstack",
    label: "Full-Stack Builds",
    count: allProjects.filter((p) => p.category === "fullstack").length,
  },
];

// Map category to design-system glow color
const glowClass: Record<string, string> = {
  wordpress: "hover-glow-rose",
  packages: "hover-glow-emerald",
  fullstack: "hover-glow-blue",
};

const categoryLabel: Record<string, string> = {
  wordpress: "WordPress",
  packages: "Package",
  fullstack: "Full-Stack",
};

const categoryText: Record<string, string> = {
  wordpress: "text-rose-500",
  fullstack: "text-blue-500",
  packages: "text-emerald-500",
};

const acquiredCount = allProjects.filter((p) => p.acquired).length;
const wpPluginCount = allProjects.filter((p) => p.category === "wordpress").length;
---

<Layout
  title="Projects | Open Source Plugins & Acquired Products"
  description="WooCommerce payment gateways, headless CMS plugins, and Composer packages I built and shipped — including two acquired products."
>
  <Header />
  <main class="py-24 relative overflow-hidden" id="main-content">
    <PageHero
      badge="Project Showroom"
      description="WordPress plugins I built and maintained, WooCommerce payment gateways I shipped end-to-end, and the Composer libraries underneath. Two products were acquired."
    >
      <Fragment slot="title">Shipped <span class="t-accent">software.</span></Fragment>
    </PageHero>

    <!-- Honest summary strip -->
    <section class="pb-10 relative z-10">
      <div class="mx">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-strong border border-subtle rounded-2xl overflow-hidden">
          <div class="bg-surface p-5">
            <p class="t-mono text-[10px] text-muted">Featured projects</p>
            <p class="text-2xl font-display font-extrabold text-primary mt-1.5">{featured.length}</p>
            <p class="text-[11px] text-secondary mt-1">Shipped end-to-end</p>
          </div>
          <div class="bg-surface p-5">
            <p class="t-mono text-[10px] text-muted">Acquired products</p>
            <p class="text-2xl font-display font-extrabold t-accent mt-1.5">{acquiredCount}</p>
            <p class="text-[11px] text-secondary mt-1">Successful exits</p>
          </div>
          <div class="bg-surface p-5">
            <p class="t-mono text-[10px] text-muted">WP.org plugins</p>
            <p class="text-2xl font-display font-extrabold text-primary mt-1.5">{wpPluginCount}+</p>
            <p class="text-[11px] text-secondary mt-1">Official directory</p>
          </div>
          <div class="bg-surface p-5">
            <p class="t-mono text-[10px] text-muted">Total in catalog</p>
            <p class="text-2xl font-display font-extrabold text-primary mt-1.5">{allProjects.length}</p>
            <p class="text-[11px] text-secondary mt-1">Plugins, packages, builds</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Interactive Filtering & Display -->
    <section class="pb-28 relative z-10">
      <div class="mx">
        <!-- Filter Tabs: counts reflect real data -->
        <div class="flex flex-wrap items-center gap-2 border-b border-subtle pb-6 mb-12 reveal">
          {
            filterBuckets.map((b, i) => (
              <button
                class={`filter-btn text-xs font-mono px-4 py-2 rounded-lg border border-subtle hover:border-accent transition-all cursor-pointer bg-surface ${i === 0 ? "active text-accent" : "text-secondary"}`}
                data-filter={b.id}
              >
                {b.label.toUpperCase()} <span class="opacity-60 ml-1">({b.count})</span>
              </button>
            ))
          }
        </div>

        <!-- Featured Projects List -->
        <div class="space-y-16" id="projects-list">
          {
            featured.map((p) => {
              const activeLink = p.links?.find((link) => link.active);
              return (
                <article class="project-card reveal" data-cat={p.category}>
                <div class="grid lg:grid-cols-12 gap-8 items-start">
                  {/* Side Panel Info */}
                  <div class="lg:col-span-4">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="text-[9px] font-mono text-accent uppercase tracking-widest bg-accent-glow px-2.5 py-1 rounded border border-rose-500/10 font-bold">
                        {p.type}
                      </span>
                      {isTeamContribution(p) && (
                        <span class="text-[9px] font-mono text-secondary uppercase tracking-widest bg-raised px-2.5 py-1 rounded border border-subtle font-bold">
                          Team Contribution
                        </span>
                      )}
                      {p.acquired && (
                        <span class="text-[9px] font-mono text-success uppercase tracking-widest bg-success-glow px-2.5 py-1 rounded border border-emerald-500/10 font-bold">
                          Acquired
                        </span>
                      )}
                      <span class="text-[9px] font-mono text-muted uppercase tracking-widest font-bold">
                        {categoryLabel[p.category] ?? p.category}
                      </span>
                    </div>
                    <h2 class="t-title text-2xl font-bold mt-4 text-primary">{p.title}</h2>
                    {p.subtitle && (
                      <p class="text-xs font-mono text-secondary mt-2.5 flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true" />
                        {p.subtitle}
                      </p>
                    )}
                    {activeLink && (
                      <a
                        href={activeLink.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="mt-3 inline-flex items-center gap-1 text-[11px] font-mono text-secondary hover:text-accent transition-colors"
                      >
                        <Icon name="ph:link" class="w-3.5 h-3.5" aria-hidden="true" />
                        {activeLink.url.replace(/^https?:\/\//, "").replace(/\/$/, "")}
                      </a>
                    )}
                  </div>

                  {/* Expanded Detail Card */}
                  <div class="lg:col-span-8">
                    <div class={`glass ${glowClass[p.category] ?? "hover-glow-rose"} p-8 bg-surface border-subtle flex flex-col justify-between min-h-[220px]`}>
                      <div>
                        <div class="flex flex-wrap gap-1.5 mb-6">
                          {p.tech.map((t) => (
                            <span class="tag">{t}</span>
                          ))}
                        </div>

                        {/* Modules (optional, for ecosystem-style products) */}
                        {p.modules && p.modules.length > 0 && (
                          <div class="mb-6 p-4 rounded-lg bg-deep border border-subtle">
                            <p class="t-mono text-[9px] text-muted uppercase tracking-widest font-bold mb-2">
                              Shipped Plugins / Modules
                            </p>
                            <div class="flex flex-wrap gap-1.5">
                              {p.modules.map((m) => (
                                <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-surface border border-subtle text-secondary">
                                  {m}
                                </span>
                              ))}
                            </div>
                          </div>
                        )}

                        {/* Overview */}
                        <p class="text-sm text-primary leading-relaxed font-sans mb-6 font-medium">{p.overview}</p>

                        {/* Problem & Solution Block */}
                        <div class="grid sm:grid-cols-2 gap-6 mt-6 border-t border-subtle pt-6">
                          <div>
                            <h4 class="text-[10px] font-mono uppercase tracking-wider text-accent font-bold mb-2">
                              The Problem
                            </h4>
                            <p class="text-xs text-secondary leading-relaxed font-sans">{p.problem}</p>
                          </div>
                          <div>
                            <h4 class="text-[10px] font-mono uppercase tracking-wider text-success font-bold mb-2">
                              The Solution
                            </h4>
                            <p class="text-xs text-secondary leading-relaxed font-sans">{p.solution}</p>
                          </div>
                        </div>

                        {/* Role & Challenges */}
                        <div class="grid sm:grid-cols-2 gap-6 mt-6 border-t border-subtle pt-6">
                          <div>
                            <h4 class="text-[10px] font-mono uppercase tracking-wider text-muted font-bold mb-1">
                              My Role
                            </h4>
                            <p class="text-xs text-primary font-semibold font-sans">{p.role}</p>
                          </div>
                          <div>
                            <h4 class="text-[10px] font-mono uppercase tracking-wider text-muted font-bold mb-1">
                              Key Challenges
                            </h4>
                            <p class="text-xs text-secondary leading-relaxed font-sans">{p.challenges}</p>
                          </div>
                        </div>

                        {/* Impact Block */}
                        {p.impact && (
                          <div class="t-body text-xs mt-6 text-secondary font-medium bg-raised p-4 rounded-lg border border-subtle">
                            <strong class="text-accent-bright font-mono uppercase text-[9px] tracking-widest block mb-1">
                              Measurable Impact
                            </strong>
                            <span set:html={p.impact} />
                          </div>
                        )}
                      </div>

                      {/* Direct Links */}
                      {activeLink && (
                        <div class="flex flex-wrap gap-4 mt-8 pt-6 border-t border-subtle">
                          <a
                            href={activeLink.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class={`b ${activeLink.data?.type === "primary" ? "b-primary" : "b-ghost"} text-xs flex items-center gap-1`}
                          >
                            {activeLink.title}
                            <span aria-hidden="true">&rarr;</span>
                          </a>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </article>
            );
          })
          }

          <!-- Rest Secondary Grid -->
          <div class="pt-16 border-t border-subtle" id="secondary-grid-header">
            <span class="t-mono text-xs text-muted tracking-wider uppercase font-bold"
              >Secondary implementations &amp; integrations</span
            >
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8" id="secondary-grid">
              {
                rest.map((p) => {
                  const activeLink = p.links?.find((link) => link.active);
                  return (
                    <div
                      class={`project-card glass bg-surface hover:-translate-y-0.5 transition-all flex flex-col justify-between group ${glowClass[p.category] ?? "hover-glow-rose"}`}
                      data-cat={p.category}
                    >
                      {/* Top bar: category + status badges */}
                      <div class="flex items-center justify-between gap-2 px-5 pt-5 pb-3 border-b border-subtle">
                        <span class={`text-[9px] font-mono uppercase tracking-widest font-bold ${categoryText[p.category] ?? "text-muted"}`}>
                          {categoryLabel[p.category] ?? p.category}
                        </span>
                        <div class="flex items-center gap-1.5">
                          {isTeamContribution(p) && (
                            <span class="text-[9px] font-mono text-secondary uppercase tracking-widest bg-raised px-2 py-0.5 rounded border border-subtle font-bold">
                              Team
                            </span>
                          )}
                          {p.acquired && (
                            <span class="text-[9px] font-mono text-success uppercase tracking-widest bg-success-glow px-2 py-0.5 rounded border border-emerald-500/10 font-bold">
                              Acquired
                            </span>
                          )}
                        </div>
                      </div>

                      {/* Body: type → title → overview → tech → CTA */}
                      <div class="p-5 flex flex-col gap-3 flex-grow justify-between">
                        <div class="flex flex-col gap-3">
                          <span class="t-mono text-[9px] text-accent uppercase tracking-widest font-bold">
                            {p.type}
                          </span>

                          <h4 class="font-bold text-base text-primary leading-tight">
                            {activeLink ? (
                              <a
                                href={activeLink.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="hover:text-accent transition-colors"
                              >
                                {(() => {
                                  const words = p.title.split(" ");
                                  const last = words.pop();
                                  const prefix = words.join(" ");
                                  return (
                                    <>
                                      {prefix ? prefix + " " : ""}
                                      <span class="whitespace-nowrap">
                                        {last}
                                        <Icon
                                          name="ph:arrow-square-out"
                                          class="inline-block w-3.5 h-3.5 ml-1 opacity-70 group-hover:opacity-100 transition-opacity align-middle relative -top-0.5"
                                          aria-hidden="true"
                                        />
                                      </span>
                                    </>
                                  );
                                })()}
                              </a>
                            ) : (
                              p.title
                            )}
                          </h4>

                          {p.subtitle && (
                            <p class="text-xs font-mono text-secondary flex items-center gap-1.5">
                              <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true" />
                              {p.subtitle}
                            </p>
                          )}

                          <p class="text-xs text-secondary leading-relaxed line-clamp-3">
                            {p.overview}
                          </p>
                        </div>

                        <div class="flex flex-col gap-3 mt-auto">
                          {p.tech && p.tech.length > 0 && (
                            <div class="flex items-center gap-1 mt-1 overflow-hidden flex-nowrap">
                              {p.tech.slice(0, 3).map((t) => (
                                <span class="tag shrink-0">{t}</span>
                              ))}
                              {p.tech.length > 3 && (
                                <span class="text-[10px] font-mono text-muted px-1.5 py-0.5 shrink-0">
                                  +{p.tech.length - 3}
                                </span>
                              )}
                            </div>
                          )}

                          {activeLink && (
                            <div class="pt-1">
                              <a
                                href={activeLink.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-[11px] text-accent font-semibold hover:underline"
                              >
                                {activeLink.title} &rarr;
                              </a>
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  );
                })
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Button Active Overrides */
  .filter-btn.active {
    border-color: var(--accent) !important;
    background: var(--accent-glow) !important;
    color: var(--accent-bright) !important;
  }

  /* Project Card Transition */
  .project-card {
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }
  .project-card.filtered-out {
    display: none !important;
  }
</style>

<script>
  // Client-side project filter logic
  var buttons = document.querySelectorAll(".filter-btn");
  var cards = document.querySelectorAll(".project-card");
  var secondaryHeader = document.getElementById("secondary-grid-header");
  var secondaryGrid = document.getElementById("secondary-grid");

  if (buttons.length && cards.length) {
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((b) => {
          b.classList.remove("active", "text-accent");
          b.classList.add("text-secondary");
        });
        btn.classList.add("active", "text-accent");
        btn.classList.remove("text-secondary");

        var filterVal = btn.getAttribute("data-filter");
        let visibleSecondaryCount = 0;

        cards.forEach((card) => {
          var cardCat = card.getAttribute("data-cat");
          if (filterVal === "all" || cardCat === filterVal) {
            card.classList.remove("filtered-out");
            card.style.opacity = "0";
            setTimeout(function() {
              card.style.opacity = "1";
            }, 50);

            if (card.parentElement && card.parentElement.id === "secondary-grid") {
              visibleSecondaryCount++;
            }
          } else {
            card.classList.add("filtered-out");
          }
        });

        if (secondaryHeader && secondaryGrid) {
          secondaryHeader.style.display = visibleSecondaryCount === 0 && filterVal !== "all" ? "none" : "block";
        }
      });
    });
  }

</script>
