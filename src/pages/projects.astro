---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const featured = [
  {
    title: "WP Last Modified Info",
    desc: "A WordPress plugin that intelligently displays last modified dates for posts, pages, and custom post types. Supports Gutenberg blocks, custom shortcodes, and search engine schema.org JSON-LD microdata overrides.",
    details: "20,000+ active installs · 1,000,000+ downloads · 4.5 stars on WordPress.org",
    tags: ["PHP", "WordPress", "Gutenberg", "Schema.org", "SEO"],
    url: "https://wordpress.org/plugins/wp-last-modified-info/",
    category: "wordpress"
  },
  {
    title: "RevivePress",
    desc: "Automatically republishes and clones old posts on customized time schedules. Revitalizes outdated content to front pages and feeds for improved indexing traffic, while protecting database logs.",
    details: "7,000+ active installs · Premium versions active · Action scheduler core",
    tags: ["PHP", "WordPress", "Cron", "Automation", "SEO"],
    url: "https://wordpress.org/plugins/revivepress/",
    category: "wordpress"
  },
];

const rest = [
  {
    title: "shuvamrahamusic",
    desc: "High-performance visual portfolio and guitar academy website built for guitarist Shuvam Raha, featuring custom media streaming and responsive layouts.",
    tags: ["TypeScript", "Next.js", "Tailwind CSS", "React"],
    url: "https://www.shuvamrahamusic.com",
    category: "fullstack"
  },
  {
    title: "rajsevent",
    desc: "A sleek visual landing page built for Raj's Event Management, optimized for high PageSpeed indices and fluid scrolling transitions.",
    tags: ["React", "TypeScript", "Tailwind CSS", "Astro"],
    url: "https://www.rajsevent.com",
    category: "fullstack"
  },
  {
    title: "Connect Helpers",
    desc: "Core Composer dependency library powering InstaWP remote management. Handles API handshake auth protocols, backup sync, and remote operations.",
    tags: ["PHP", "Composer", "Security", "REST API"],
    url: "https://github.com/iamsayan",
    category: "packages"
  },
  {
    title: "WaaS Integration",
    desc: "InstaWP site provisioning system supporting WooCommerce, SureCart, and EDD gateways for seamless template cloning and billing.",
    tags: ["PHP", "InstaWP", "WooCommerce", "EDD"],
    url: "https://github.com/iamsayan",
    category: "wordpress"
  },
  {
    title: "Gutena Blocks",
    desc: "React-built custom layout widgets (tabs, accordion containers, and testimonial sliders) for the WordPress block editor.",
    tags: ["React", "Gutenberg", "TypeScript", "WordPress"],
    url: "https://github.com/iamsayan",
    category: "wordpress"
  },
  {
    title: "advanced-cron-scheduler",
    desc: "Helper plugin designed to seamlessly migrate standard WordPress WP-Cron tasks into WooCommerce's high-performance Action Scheduler.",
    tags: ["PHP", "WordPress", "Action Scheduler", "Database"],
    url: "https://wordpress.org/plugins/migrate-wp-cron-to-action-scheduler/",
    category: "wordpress"
  },
  {
    title: "simple-posts-ticker",
    desc: "A lightweight recent posts marquee slider customizable through the WordPress customization API.",
    tags: ["PHP", "WordPress", "CSS Marquee", "jQuery"],
    url: "https://wordpress.org/plugins/simple-posts-ticker/",
    category: "wordpress"
  },
  {
    title: "remove-wp-meta-tags",
    desc: "Performance utility that sanitizes unused meta elements and tags in the WordPress document header.",
    tags: ["PHP", "WordPress", "Web Performance"],
    url: "https://wordpress.org/plugins/remove-wp-meta-tags/",
    category: "wordpress"
  },
  {
    title: "change-wp-page-permalinks",
    desc: "Adds custom permalink extensions (.html, .php, or .aspx) directly to WordPress pages for legacy routing migrations.",
    tags: ["PHP", "WordPress", "Permalinks", "SEO"],
    url: "https://wordpress.org/plugins/change-wp-page-permalinks/",
    category: "wordpress"
  },
  {
    title: "ultimate-facebook-comments",
    desc: "Simplifies embedding of responsive Facebook comments boxes onto WordPress blogs and page components.",
    tags: ["PHP", "WordPress", "Facebook API", "Social"],
    url: "https://wordpress.org/plugins/ultimate-facebook-comments/",
    category: "wordpress"
  },
];
---

<Layout title="Projects | Sayan Datta" description="Browse all WordPress plugins, custom SaaS products, Composer libraries, and open-source contributions.">
  <Header />
  <main class="py-24 relative overflow-hidden">
    <!-- Background overlay grid -->
    <div class="absolute inset-0 opacity-[0.08] pointer-events-none" style="background:radial-gradient(circle at 80% 30%, var(--accent), transparent 50%)"></div>

    <section class="pt-16 pb-8 relative z-10">
      <div class="mx">
        <p class="t-mono text-[var(--accent)] uppercase font-bold">Project Showroom</p>
        <h1 class="t-heading mt-4 reveal r1">Shipped Software.</h1>
        <p class="t-body mt-6 max-w-2xl reveal r2">
          Explore WordPress plugins with over a million downloads, Composer packages, and modern full-stack web applications. Select a category below to filter.
        </p>
      </div>
    </section>

    <!-- Interactive Filtering & Display -->
    <section class="pb-28 relative z-10">
      <div class="mx">
        <!-- Filter Tabs -->
        <div class="flex flex-wrap items-center gap-2 border-b border-[var(--border-subtle)] pb-6 mb-12 reveal">
          <button class="filter-btn active text-xs font-mono px-4 py-2 rounded-lg border border-[var(--border-subtle)] hover:border-[var(--accent)] transition-all cursor-pointer bg-[var(--bg-surface)] text-[var(--accent)]" data-filter="all">ALL PROJECTS</button>
          <button class="filter-btn text-xs font-mono px-4 py-2 rounded-lg border border-[var(--border-subtle)] hover:border-[var(--accent)] transition-all cursor-pointer bg-[var(--bg-surface)] text-[var(--text-secondary)]" data-filter="wordpress">WP PLUGINS</button>
          <button class="filter-btn text-xs font-mono px-4 py-2 rounded-lg border border-[var(--border-subtle)] hover:border-[var(--accent)] transition-all cursor-pointer bg-[var(--bg-surface)] text-[var(--text-secondary)]" data-filter="fullstack">WEB APPS</button>
          <button class="filter-btn text-xs font-mono px-4 py-2 rounded-lg border border-[var(--border-subtle)] hover:border-[var(--accent)] transition-all cursor-pointer bg-[var(--bg-surface)] text-[var(--text-secondary)]" data-filter="packages">LIBRARIES / PACKAGES</button>
        </div>

        <!-- Featured Projects List -->
        <div class="space-y-16" id="projects-list">
          {featured.map((p, i) => (
            <div class="project-card reveal" data-cat={p.category}>
              <div class="grid lg:grid-cols-12 gap-8 items-start">
                <div class="lg:col-span-4 lg:sticky lg:top-24">
                  <span class="text-xs font-mono text-[var(--accent)] uppercase tracking-wider bg-[var(--accent-glow)] px-3 py-1 rounded-md border border-rose-500/10">FEATURED RELEASE</span>
                  <h2 class="t-title text-2xl font-bold mt-3">{p.title}</h2>
                  <p class="text-xs font-mono text-[var(--text-secondary)] mt-2 leading-relaxed">{p.details}</p>
                </div>
                <div class="lg:col-span-8">
                  <div class="glass hover-glow-rose p-8 bg-[var(--bg-surface)] border-[var(--border-subtle)] flex flex-col justify-between min-h-[220px]">
                    <div>
                      <div class="flex flex-wrap gap-2 mb-4">
                        {p.tags.map(t => <span class="tag">{t}</span>)}
                      </div>
                      <p class="t-body text-sm leading-relaxed">{p.desc}</p>
                    </div>
                    <a href={p.url} target="_blank" rel="noopener noreferrer" class="b b-primary mt-6 self-start shadow-md text-xs">
                      View in Directory
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}

          <!-- Rest Secondary Grid -->
          <div class="pt-8 border-t border-[var(--border-subtle)]" id="secondary-grid-header">
            <span class="t-mono text-xs text-[var(--text-muted)] tracking-wider uppercase font-bold">Secondary Implementations &amp; Integrations</span>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8" id="secondary-grid">
              {rest.map(p => (
                <div class="project-card glass p-6 bg-[var(--bg-surface)] border-[var(--border-subtle)] hover:-translate-y-1 transition-all flex flex-col justify-between" data-cat={p.category}>
                  <div>
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {p.tags.map(t => <span class="tag">{t}</span>)}
                    </div>
                    <h3 class="text-md font-bold text-[var(--text-primary)]">{p.title}</h3>
                    <p class="text-xs text-[var(--text-secondary)] mt-3 leading-relaxed">{p.desc}</p>
                  </div>
                  
                  <a href={p.url} target="_blank" rel="noopener noreferrer" class="pt-4 flex items-center gap-1.5 text-xs text-[var(--accent)] font-semibold mt-4 hover:underline">
                    <span>Source / Website</span>
                    <span>&rarr;</span>
                  </a>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Button Active Overrides */
  .filter-btn.active {
    border-color: var(--accent) !important;
    background: var(--accent-glow) !important;
    color: var(--accent-bright) !important;
  }
  
  /* Project Card Transition */
  .project-card {
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .project-card.filtered-out {
    display: none !important;
  }
</style>

<script>
  // Client-side project filter logic
  var buttons = document.querySelectorAll(".filter-btn");
  var cards = document.querySelectorAll(".project-card");
  var secondaryHeader = document.getElementById("secondary-grid-header");
  var secondaryGrid = document.getElementById("secondary-grid");

  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      // Toggle button states
      buttons.forEach(b => {
        b.classList.remove("active");
        b.classList.remove("text-[var(--accent)]");
        b.classList.add("text-[var(--text-secondary)]");
      });
      btn.classList.add("active");
      btn.classList.remove("text-[var(--text-secondary)]");
      btn.classList.add("text-[var(--accent)]");

      var filterVal = btn.getAttribute("data-filter");

      let visibleSecondaryCount = 0;

      // Filter project cards
      cards.forEach(card => {
        var cardCat = card.getAttribute("data-cat");
        if (filterVal === "all" || cardCat === filterVal) {
          card.classList.remove("filtered-out");
          // Fade animation
          card.style.opacity = "0";
          setTimeout(() => {
            card.style.opacity = "1";
          }, 50);
          
          if (card.parentElement.id === "secondary-grid") {
            visibleSecondaryCount++;
          }
        } else {
          card.classList.add("filtered-out");
        }
      });

      // Show or hide secondary section depending on visible cards
      if (visibleSecondaryCount === 0 && filterVal !== "all") {
        secondaryHeader.style.display = "none";
      } else {
        secondaryHeader.style.display = "block";
      }
    });
  });

  // IntersectionObserver reveal animations
  var observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
      }
    });
  }, { threshold: 0.05 });
  
  document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
</script>
