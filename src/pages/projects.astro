---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getProjects } from "@/lib/data";

const allProjects = await getProjects();
// First 4 are high impact featured plugins/products
const featured = allProjects.filter(p => p.featured);
const rest = allProjects.filter(p => !p.featured);
---

<Layout title="Projects | Open Source Plugins & Acquired Products" description="Explore WooCommerce checkouts, custom payment integrations, Composer packages, and open-source contributions by Sayan Datta.">
  <Header />
  <main class="py-24 relative overflow-hidden" id="main-content">
    <!-- Background overlay grid -->
    <div class="absolute inset-0 opacity-[0.08] pointer-events-none" style="background:radial-gradient(circle at 80% 30%, var(--accent), transparent 50%)" aria-hidden="true"></div>

    <section class="pt-16 pb-8 relative z-10">
      <div class="mx">
        <p class="t-mono text-accent uppercase font-bold">Project Showroom</p>
        <h1 class="t-heading mt-4 reveal r1">Shipped Software.</h1>
        <p class="t-body mt-6 max-w-2xl reveal r2">
          Explore e-commerce systems, open-source plugins, Composer libraries, and full-stack software. Select a category below to filter.
        </p>
      </div>
    </section>

    <!-- Interactive Filtering & Display -->
    <section class="pb-28 relative z-10">
      <div class="mx">
        <!-- Filter Tabs -->
        <div class="flex flex-wrap items-center gap-2 border-b border-subtle pb-6 mb-12 reveal">
          <button class="filter-btn active text-xs font-mono px-4 py-2 rounded-lg border border-subtle hover:border-accent transition-all cursor-pointer bg-surface text-accent" data-filter="all">ALL PROJECTS</button>
          <button class="filter-btn text-xs font-mono px-4 py-2 rounded-lg border border-subtle hover:border-accent transition-all cursor-pointer bg-surface text-secondary" data-filter="wordpress">WP PLUGINS</button>
          <button class="filter-btn text-xs font-mono px-4 py-2 rounded-lg border border-subtle hover:border-accent transition-all cursor-pointer bg-surface text-secondary" data-filter="packages">LIBRARIES / PACKAGES</button>
        </div>

        <!-- Featured Projects List -->
        <div class="space-y-16" id="projects-list">
          {featured.map((p) => (
            <div class="project-card reveal" data-cat={p.category}>
              <div class="grid lg:grid-cols-12 gap-8 items-start">
                <!-- Side Panel Info -->
                <div class="lg:col-span-4 lg:sticky lg:top-24">
                  <span class="text-[9px] font-mono text-accent uppercase tracking-widest bg-accent-glow px-2.5 py-1 rounded border border-rose-500/10 font-bold block w-fit">{p.type}</span>
                  <h2 class="t-title text-2xl font-bold mt-4 text-primary">{p.title}</h2>
                  <p class="text-xs font-mono text-secondary mt-2.5 flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                    {p.downloads}
                  </p>
                </div>
                
                <!-- Expanded Detail Card -->
                <div class="lg:col-span-8">
                  <div class="glass hover-glow-rose p-8 bg-surface border-subtle flex flex-col justify-between min-h-[220px]">
                    <div>
                      <div class="flex flex-wrap gap-1.5 mb-6">
                        {p.tech.map(t => <span class="tag">{t}</span>)}
                      </div>
                      
                      <!-- Overview -->
                      <p class="text-sm text-primary leading-relaxed font-sans mb-6 font-medium">
                        {p.overview}
                      </p>

                      <!-- Problem & Solution Block -->
                      <div class="grid sm:grid-cols-2 gap-6 mt-6 border-t border-subtle pt-6">
                        <div>
                          <h4 class="text-[10px] font-mono uppercase tracking-wider text-accent font-bold mb-2">The Problem</h4>
                          <p class="text-xs text-secondary leading-relaxed font-sans">{p.problem}</p>
                        </div>
                        <div>
                          <h4 class="text-[10px] font-mono uppercase tracking-wider text-success font-bold mb-2">The Solution</h4>
                          <p class="text-xs text-secondary leading-relaxed font-sans">{p.solution}</p>
                        </div>
                      </div>

                      <!-- Role & Challenges -->
                      <div class="grid sm:grid-cols-2 gap-6 mt-6 border-t border-subtle pt-6">
                        <div>
                          <h4 class="text-[10px] font-mono uppercase tracking-wider text-muted font-bold mb-1">My Role</h4>
                          <p class="text-xs text-primary font-semibold font-sans">{p.role}</p>
                        </div>
                        <div>
                          <h4 class="text-[10px] font-mono uppercase tracking-wider text-muted font-bold mb-1">Key Challenges</h4>
                          <p class="text-xs text-secondary leading-relaxed font-sans">{p.challenges}</p>
                        </div>
                      </div>

                      <!-- Impact Block -->
                      {p.impact && (
                        <div class="t-body text-xs mt-6 text-secondary font-medium bg-raised p-4 rounded-lg border border-subtle">
                          <strong class="text-accent-bright font-mono uppercase text-[9px] tracking-widest block mb-1">Measurable Impact</strong>
                          {p.impact}
                        </div>
                      )}
                    </div>

                    <!-- Direct Links -->
                    <div class="flex flex-wrap gap-4 mt-8 pt-6 border-t border-subtle">
                      <a href={p.url} target="_blank" rel="noopener noreferrer" class="b b-primary text-xs flex items-center gap-1.5 shadow-md">
                        View Directory / Live
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                      </a>
                      {p.links && p.links.map(link => (
                        <a href={link.url} target="_blank" rel="noopener noreferrer" class="b b-ghost text-xs flex items-center gap-1">
                          {link.label}
                          <span aria-hidden="true">&rarr;</span>
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}

          <!-- Rest Secondary Grid -->
          <div class="pt-16 border-t border-subtle" id="secondary-grid-header">
            <span class="t-mono text-xs text-muted tracking-wider uppercase font-bold">Secondary Implementations &amp; Integrations</span>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8" id="secondary-grid">
              {rest.map(p => (
                <div class="project-card glass p-6 bg-surface border-subtle hover:-translate-y-1 transition-all flex flex-col justify-between" data-cat={p.category}>
                  <div>
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {p.tech.map(t => <span class="tag">{t}</span>)}
                    </div>
                    <span class="text-[9px] font-mono text-muted uppercase tracking-wider block mb-1 font-bold">{p.type}</span>
                    <h3 class="text-md font-bold text-primary mt-1">{p.title}</h3>
                    <p class="text-xs text-secondary mt-3 leading-relaxed font-sans">{p.description}</p>
                  </div>
                  
                  <a href={p.url} target="_blank" rel="noopener noreferrer" class="pt-4 flex items-center gap-1.5 text-xs text-accent font-semibold mt-4 hover:underline">
                    <span>Source / Website</span>
                    <span aria-hidden="true">&rarr;</span>
                  </a>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Button Active Overrides */
  .filter-btn.active {
    border-color: var(--accent) !important;
    background: var(--accent-glow) !important;
    color: var(--accent-bright) !important;
  }
  
  /* Project Card Transition */
  .project-card {
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .project-card.filtered-out {
    display: none !important;
  }
</style>

<script>
  // Client-side project filter logic
  var buttons = document.querySelectorAll(".filter-btn");
  var cards = document.querySelectorAll(".project-card");
  var secondaryHeader = document.getElementById("secondary-grid-header");
  var secondaryGrid = document.getElementById("secondary-grid");

  if (buttons.length && cards.length) {
    buttons.forEach(btn => {
      btn.addEventListener("click", () => {
        // Toggle button states
        buttons.forEach(b => {
          b.classList.remove("active");
          b.classList.remove("text-accent");
          b.classList.add("text-secondary");
        });
        btn.classList.add("active");
        btn.classList.remove("text-secondary");
        btn.classList.add("text-accent");

        var filterVal = btn.getAttribute("data-filter");

        let visibleSecondaryCount = 0;

        // Filter project cards
        cards.forEach(card => {
          var cardCat = card.getAttribute("data-cat");
          if (filterVal === "all" || cardCat === filterVal) {
            card.classList.remove("filtered-out");
            card.style.opacity = "0";
            setTimeout(() => {
              card.style.opacity = "1";
            }, 50);
            
            if (card.parentElement.id === "secondary-grid") {
              visibleSecondaryCount++;
            }
          } else {
            card.classList.add("filtered-out");
          }
        });

        // Hide secondary grid container if empty
        if (secondaryHeader && secondaryGrid) {
          if (visibleSecondaryCount === 0 && filterVal !== "all") {
            secondaryHeader.style.display = "none";
          } else {
            secondaryHeader.style.display = "block";
          }
        }
      });
    });
  }

  // Unified single IntersectionObserver for page animate triggers
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible");
      }
    });
  }, { threshold: 0.05 });
  
  document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
</script>
