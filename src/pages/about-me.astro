---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getProfile, getExperience, getTestimonials } from "@/lib/data";
import { Icon } from "astro-icon/components";
import PageHero from "@/components/PageHero.astro";

const profile = await getProfile();
const experience = await getExperience();
const testimonials = await getTestimonials();
---

<Layout
  title="About | Sayan Datta — Senior Developer"
  description="8+ years of e-commerce engineering experience. From scaling WooCommerce checkouts to modern full-stack systems."
>
  <Header />
  <main id="main-content" class="py-24 relative overflow-hidden">
    <PageHero
      badge="About Me"
      description={`I'm ${profile.name} — a software engineer who turns product blueprints into clean, scalable, and performant web solutions.`}
    >
      <Fragment slot="title">The person behind the <span class="t-accent">code.</span></Fragment>
    </PageHero>

    <div class="mx relative z-10">
      <!-- Main Profile Summary Split -->
      <div class="grid lg:grid-cols-12 gap-12 items-start mb-24 reveal r1">
        <!-- Biography Text -->
        <div class="lg:col-span-8 space-y-6">
          <p class="t-body leading-relaxed font-sans">
            {profile.bios.long}
          </p>
          <p class="t-body leading-relaxed font-sans">
            With a focus on performance-first engineering, I ensure that web applications load in milliseconds, backend
            structures remain clean and linted, and custom plugin architectures map to standard scalable workflows.
          </p>
        </div>

        <!-- Quick Info Panel -->
        <div class="lg:col-span-4">
          <div class="glass p-6 border-strong bg-surface space-y-4">
            <h3 class="font-bold text-sm text-primary uppercase tracking-wider border-b border-subtle pb-2">
              Quick Stats
            </h3>
            <div class="space-y-3">
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted">Location:</span>
                <span class="font-medium text-primary">🇮🇳 {profile.location}</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted">Email:</span>
                <a href={`mailto:${profile.email}`} class="font-semibold text-accent hover:underline">{profile.email}</a
                >
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted">Website:</span>
                <span class="font-medium text-primary">sayandatta.co.in</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted">Freelance:</span>
                <span class="status-badge !py-0.5 !px-2.5 !text-[11px]"
                  ><span class="pulse-dot" aria-hidden="true"></span>Available</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Setup and Stack Details (Daily Tools) -->
      <div class="mb-24 reveal r2">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500" aria-hidden="true"></span>
          <span class="text-[10px] font-mono tracking-wider text-blue-500 uppercase font-bold">My Setup</span>
        </div>
        <h2 class="t-title mb-10">Tools I use daily.</h2>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Hardware Card -->
          <div class="glass hover-glow-blue p-6 bg-surface">
            <h3 class="font-bold text-base text-primary mb-4 flex items-center gap-2">
              <Icon name="ph:desktop" class="w-4 h-4 text-blue-500" aria-hidden="true" />
              Hardware
            </h3>
            <ul class="space-y-2 text-xs text-secondary font-sans">
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-blue-500" aria-hidden="true"></span>Windows Workstation PC
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-blue-500" aria-hidden="true"></span>Dell UltraSharp 4K display
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-blue-500" aria-hidden="true"></span>Mechanical MX Brown Keyboard
              </li>
            </ul>
          </div>

          <!-- Development Card -->
          <div class="glass hover-glow-emerald p-6 bg-surface">
            <h3 class="font-bold text-base text-primary mb-4 flex items-center gap-2">
              <Icon name="ph:terminal-window" class="w-4 h-4 text-emerald-500" aria-hidden="true" />
              Development
            </h3>
            <ul class="space-y-2 text-xs text-secondary font-sans">
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-emerald-500" aria-hidden="true"></span>VS Code &amp; Cursor IDEs
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-emerald-500" aria-hidden="true"></span>Windows Terminal (ZSH)
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-emerald-500" aria-hidden="true"></span>Git Version Control
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-emerald-500" aria-hidden="true"></span>Docker Containers
              </li>
            </ul>
          </div>

          <!-- Design Card -->
          <div class="glass hover-glow-rose p-6 bg-surface">
            <h3 class="font-bold text-base text-primary mb-4 flex items-center gap-2">
              <Icon name="ph:palette" class="w-4 h-4 text-rose-500" aria-hidden="true" />
              UI / UX
            </h3>
            <ul class="space-y-2 text-xs text-secondary font-sans">
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-rose-500" aria-hidden="true"></span>Figma Design Board
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-rose-500" aria-hidden="true"></span>Adobe XD Prototyping
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-rose-500" aria-hidden="true"></span>Graph Paper Sketching
              </li>
            </ul>
          </div>

          <!-- Infrastructure Card -->
          <div class="glass hover-glow-amber p-6 bg-surface">
            <h3 class="font-bold text-base text-primary mb-4 flex items-center gap-2">
              <Icon name="ph:hard-drives" class="w-4 h-4 text-amber-500" aria-hidden="true" />
              Infrastructure
            </h3>
            <ul class="space-y-2 text-xs text-secondary font-sans">
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-amber-500" aria-hidden="true"></span>Vercel Cloud Deploy
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-amber-500" aria-hidden="true"></span>DigitalOcean VPS Droplets
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-amber-500" aria-hidden="true"></span>Cloudflare Proxy DNS
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Experience Timeline section -->
      <div class="mb-24 reveal r3">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-rose-500" aria-hidden="true"></span>
          <span class="text-[10px] font-mono tracking-wider text-rose-500 uppercase font-bold">Timeline</span>
        </div>
        <h2 class="t-title mb-12">Professional experience.</h2>

        <div class="timeline-container space-y-12">
          {
            experience.map((exp, idx) => {
              const colors = ["#f43f5e", "#38bdf8", "#a855f7", "#10b981", "#f59e0b", "#e11d48"];
              const color = colors[idx % colors.length];
              return (
                <div class="relative pl-6">
                  <div class="timeline-node" style={`border-color: ${color}; box-shadow: 0 0 10px ${color}80`} />
                  <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-2">
                    <div>
                      <h3 class="font-bold text-lg text-primary">{exp.position}</h3>
                      <p class="text-xs font-semibold" style={`color: ${color}`}>
                        {exp.company} &mdash; Remote
                      </p>
                    </div>
                    <span class="text-xs bg-raised border border-strong px-3 py-1 rounded-full text-secondary font-medium">
                      {exp.duration}
                    </span>
                  </div>
                  <p class="text-sm text-secondary leading-relaxed mb-3 font-sans">{exp.description}</p>
                  <ul class="list-disc pl-4 space-y-1 text-xs text-muted font-sans">
                    {exp.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </div>
              );
            })
          }
        </div>
      </div>

      <!-- Verified References & Testimonials Section -->
      {
        testimonials && testimonials.length > 0 && (
          <div class="mb-24 reveal r4">
            <div class="flex items-center gap-3 mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse" aria-hidden="true" />
              <span class="text-[10px] font-mono tracking-wider text-accent uppercase font-bold">
                Verified References
              </span>
            </div>
            <h2 class="t-title mb-10">Kind words from peers.</h2>

            <div class="grid md:grid-cols-2 gap-8">
              {testimonials.map((t) => (
                <div class="glass p-8 bg-surface border-subtle hover:border-accent transition-colors relative flex flex-col justify-between">
                  <blockquote class="text-sm text-secondary leading-relaxed font-sans italic mb-6">
                    "{t.text}"
                  </blockquote>
                  <div class="border-t border-subtle pt-4 flex items-center justify-between">
                    <div>
                      <cite class="text-sm font-bold text-primary not-italic block">{t.name}</cite>
                      <span class="text-[10px] font-mono text-muted block mt-0.5">{t.role}</span>
                    </div>
                    <span
                      class="text-[9px] bg-accent-glow text-accent border border-rose-500/10 px-2 py-0.5 rounded font-semibold tracking-wider font-mono uppercase"
                      aria-label="Verified testimonial endorsement"
                    >
                      Verified Reference
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )
      }

      <!-- Volunteering and open-source contributions -->
      <div class="grid md:grid-cols-2 gap-8 mb-24 reveal r4">
        <div class="glass p-8 hover-glow-purple bg-surface">
          <p class="t-mono text-purple-400 text-[10px] mb-2">COMMUNITY ENGAGEMENT</p>
          <h3 class="font-bold text-base text-primary">Volunteer Developer</h3>
          <p class="text-xs text-muted mt-1 mb-4">Jagadhatri Online &mdash; Aug 2020 - Present</p>
          <p class="text-sm text-secondary leading-relaxed font-sans">
            Volunteered to build and maintain the event and commerce portal utilizing Next.js, managing API sync
            frameworks with local WooCommerce catalogs.
          </p>
        </div>

        <div class="glass p-8 hover-glow-rose bg-surface">
          <p class="t-mono text-rose-400 text-[10px] mb-2">OPEN SOURCE ECOSYSTEM</p>
          <h3 class="font-bold text-base text-primary">Core &amp; Plugin Contributor</h3>
          <p class="text-xs text-muted mt-1 mb-4">WordPress.org &mdash; Jul 2018 - Present</p>
          <p class="text-sm text-secondary leading-relaxed font-sans">
            Submit patches, refactor actions, and provide interface enhancements inside the core WordPress platform,
            supporting open-source development globally.
          </p>
        </div>
      </div>

      <!-- Interests -->
      <div class="reveal r5">
        <p class="t-mono text-accent mb-4">Interests</p>
        <h2 class="t-title mb-6">Outside of writing code.</h2>
        <div class="flex flex-wrap gap-3">
          <span
            class="px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
            >🎵 Music</span
          >
          <span
            class="px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
            >📚 Reading Books</span
          >
          <span
            class="px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
            >🌍 Travel</span
          >
          <span
            class="px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
            >🎮 Gaming</span
          >
          <span
            class="px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
            >☕ Coffee</span
          >
          <span
            class="px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
            >🧘 Mindfulness</span
          >
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Unified single IntersectionObserver for page elements
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.05 }
  );

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
