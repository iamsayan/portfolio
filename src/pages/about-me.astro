---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getProfile, getExperiences, getTestimonials, getPhilosophy, type ExperienceItem } from "@/lib/data";
import { Icon } from "astro-icon/components";
import PageHero from "@/components/PageHero.astro";

const [profile, experience, testimonials, philosophy] = await Promise.all([
  getProfile(),
  getExperiences(),
  getTestimonials(),
  getPhilosophy(),
]);
---

<Layout
  title="About | Sayan Datta — Senior Developer"
  description="8+ years of e-commerce engineering experience. From scaling WooCommerce checkouts to modern full-stack systems."
>
  <Header />
  <main id="main-content" class="py-24 relative overflow-hidden">
    <PageHero
      badge="About Me"
      description={`I'm ${profile.name} — a software engineer who turns product blueprints into clean, scalable, and performant web solutions.`}
    >
      <Fragment slot="title">The person behind the <span class="t-accent">code.</span></Fragment>
    </PageHero>

    <div class="mx relative z-10">
      <!-- Main Profile Summary Split -->
      <div class="grid lg:grid-cols-12 gap-12 items-start mb-24 reveal r1">
        <!-- Biography Text -->
        <div class="lg:col-span-8 space-y-6">
          <p class="t-body leading-relaxed font-sans">
            {profile.bios.long}
          </p>
          <p class="t-body leading-relaxed font-sans">
            With a focus on performance-first engineering, I ensure that web applications load in milliseconds, backend
            structures remain clean and linted, and custom plugin architectures map to standard scalable workflows.
          </p>
        </div>

        <!-- Quick Info Panel -->
        <div class="lg:col-span-4">
          <div class="glass p-6 border-strong bg-surface space-y-4">
            <h3 class="font-bold text-sm text-primary uppercase tracking-wider border-b border-subtle pb-2">
              Quick Stats
            </h3>
            <div class="space-y-3">
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted flex items-center gap-1.5">
                  <Icon name="ph:map-pin" class="w-4 h-4 text-muted" />
                  Location:
                </span>
                <span class="font-medium text-primary">{profile.location}</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted flex items-center gap-1.5">
                  <Icon name="ph:briefcase" class="w-4 h-4 text-muted" />
                  Experience:
                </span>
                <span class="font-medium text-primary">{profile.experience}</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted flex items-center gap-1.5">
                  <Icon name="ph:clock" class="w-4 h-4 text-muted" />
                  Timezone:
                </span>
                <span class="font-medium text-primary">{profile.timezone}</span>
              </div>
              <!-- <div class="flex justify-between items-center text-sm">
                <span class="text-muted flex items-center gap-1.5">
                  <Icon name="ph:code" class="w-4 h-4 text-muted" />
                  Specialty:
                </span>
                <span class="font-medium text-primary">{profile.specialty}</span>
              </div> -->
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted flex items-center gap-1.5">
                  <Icon name="ph:envelope" class="w-4 h-4 text-muted" />
                  Email:
                </span>
                <div class="flex items-center gap-1.5">
                  <a href={`mailto:${profile.email}`} class="font-semibold text-accent hover:underline"
                    >{profile.email}</a
                  >
                  <button
                    class="copy-email-btn text-muted hover:text-accent transition-colors cursor-pointer flex items-center justify-center p-0.5 rounded"
                    data-email={profile.email}
                    aria-label="Copy email to clipboard"
                  >
                    <Icon name="ph:copy" class="w-3.5 h-3.5" />
                  </button>
                </div>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted flex items-center gap-1.5">
                  <Icon name="ph:globe" class="w-4 h-4 text-muted" />
                  Website:
                </span>
                <a
                  href={Astro.site || "https://sayandatta.co.in"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-medium text-primary hover:text-accent hover:underline flex items-center gap-1"
                >
                  {Astro.site ? Astro.site.host : "sayandatta.co.in"}
                  <Icon name="ph:arrow-square-out" class="w-3.5 h-3.5 text-muted" />
                </a>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-muted flex items-center gap-1.5">
                  <Icon name="ph:handshake" class="w-4 h-4 text-muted" />
                  Freelance:
                </span>
                <span class="status-badge !py-0.5 !px-2.5 !text-[11px]"
                  ><span class="pulse-dot" aria-hidden="true"></span>Available</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Setup and Stack Details (Daily Tools) -> Now Engineering Philosophy -->
      <div class="mb-24 reveal r2">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500" aria-hidden="true"></span>
          <span class="text-[10px] font-mono tracking-wider text-blue-500 uppercase font-bold">Philosophy</span>
        </div>
        <h2 class="t-title mb-10">Engineering principles.</h2>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            philosophy.map((item: any, idx: number) => {
              const glowClasses = ["hover-glow-blue", "hover-glow-emerald", "hover-glow-rose", "hover-glow-amber"];
              const textColors = ["text-blue-500", "text-emerald-500", "text-rose-500", "text-amber-500"];
              const icons = ["ph:code-block", "ph:users-three", "ph:gauge", "ph:git-fork"];
              const glow = glowClasses[idx % glowClasses.length];
              const color = textColors[idx % textColors.length];
              const icon = icons[idx % icons.length];

              return (
                <div class={`glass ${glow} p-6 bg-surface flex flex-col justify-between`}>
                  <div>
                    <h3 class="font-bold text-base text-primary mb-4 flex items-center gap-2">
                      <Icon name={icon} class={`w-4 h-4 ${color}`} aria-hidden="true" />
                      {item.title}
                    </h3>
                    <p class="text-xs text-secondary leading-relaxed font-sans">{item.description}</p>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>

      <!-- Experience Timeline section -->
      <div class="mb-24 reveal r3">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-rose-500" aria-hidden="true"></span>
          <span class="text-[10px] font-mono tracking-wider text-rose-500 uppercase font-bold">Timeline</span>
        </div>
        <h2 class="t-title mb-12">Professional experience.</h2>

        <div class="timeline-container space-y-16">
          {
            experience.map((group: ExperienceItem, idx: number) => {
              const hue = (idx * 137.5) % 360;
              const color = `hsl(${hue}, 85%, 60%)`;

              // If the company has only one role, render it directly at the root timeline level
              if (group.roles.length === 1) {
                const role = group.roles[0];
                return (
                  <div class="relative pl-6">
                    <div class="timeline-node" style={`border-color: ${color}; box-shadow: 0 0 10px ${color}80`} />
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-2">
                      <div>
                        <h3 class="font-bold text-lg text-primary flex items-center gap-2">{role.position}</h3>
                        <div class="flex flex-wrap items-center gap-2 mt-1">
                          <span class="text-xs font-semibold" style={`color: ${color}`}>
                            {group.company}
                          </span>
                          <span class="text-xs text-muted flex items-center gap-1">
                            <Icon name="ph:map-pin" class="w-3.5 h-3.5" />
                            {group.location ?? "Remote"}
                          </span>
                          {group.type?.toLowerCase() === "freelance" && (
                            <span class="inline-flex items-center rounded bg-purple-500/10 px-1.5 py-0.5 text-[9px] font-bold text-purple-400 ring-1 ring-inset ring-purple-500/20">
                              Freelance
                            </span>
                          )}
                        </div>
                      </div>
                      <span class="inline-flex items-center gap-1.5 text-xs bg-raised border border-strong px-3 py-1 rounded-full text-secondary font-sans font-medium flex-shrink-0 w-fit">
                        <Icon name="ph:calendar-blank" class="w-3.5 h-3.5 text-accent" />
                        {role.duration}
                      </span>
                    </div>
                    <p class="text-sm text-secondary leading-relaxed mb-3 font-sans">{role.description}</p>
                    <ul class="list-disc pl-4 space-y-1.5 text-xs sm:text-sm text-muted font-sans">
                      {(role.accomplishments || []).map((bullet: string) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                  </div>
                );
              }

              // If consecutive roles exist for the same company, render the nested group format
              return (
                <div class="relative pl-6">
                  {/* Main Company node */}
                  <div class="timeline-node" style={`border-color: ${color}; box-shadow: 0 0 10px ${color}80`} />

                  {/* Header: Company Name & Location */}
                  <div class="mb-4">
                    <h3 class="font-bold text-lg text-primary">{group.company}</h3>
                    <div class="flex flex-wrap items-center gap-2 mt-1">
                      <span class="text-xs text-muted flex items-center gap-1">
                        <Icon name="ph:map-pin" class="w-3.5 h-3.5" />
                        {group.location ?? "Remote"}
                      </span>
                      {group.type?.toLowerCase() === "freelance" && (
                        <span class="inline-flex items-center rounded bg-purple-500/10 px-1.5 py-0.5 text-[9px] font-bold text-purple-400 ring-1 ring-inset ring-purple-500/20">
                          Freelance
                        </span>
                      )}
                    </div>
                  </div>

                  {/* Roles Nested inside the company */}
                  <div class="space-y-8 relative pl-6 border-l border-dashed border-subtle/40 ml-1">
                    {group.roles.map((role: any) => (
                      <div class="relative last:pb-0">
                        {/* Role Node Indicator */}
                        <div
                          class="absolute -left-[29px] top-1.5 w-2 h-2 rounded-full bg-surface border"
                          style={`border-color: ${color}`}
                        />

                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-2">
                          <h4 class="font-bold text-base text-primary">{role.position}</h4>
                          <span class="inline-flex items-center gap-1.5 text-xs bg-raised border border-strong px-2.5 py-0.5 rounded-full text-secondary font-sans font-medium flex-shrink-0 w-fit">
                            <Icon name="ph:calendar-blank" class="w-3 h-3 text-accent" />
                            {role.duration}
                          </span>
                        </div>

                        <p class="text-sm text-secondary leading-relaxed mb-3 font-sans">{role.description}</p>
                        <ul class="list-disc pl-4 space-y-1.5 text-xs sm:text-sm text-muted font-sans">
                          {(role.accomplishments || []).map((bullet: string) => (
                            <li>{bullet}</li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>

      <!-- Verified References & Testimonials Section -->
      {
        testimonials && testimonials.length > 0 && (
          <div class="mb-24 reveal r4">
            <div class="flex items-center gap-3 mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse" aria-hidden="true" />
              <span class="text-[10px] font-mono tracking-wider text-accent uppercase font-bold">
                Verified References
              </span>
            </div>
            <h2 class="t-title mb-10">Kind words from peers.</h2>

            <div class="grid md:grid-cols-2 gap-8">
              {testimonials.map((t) => (
                <div class="glass p-8 bg-surface border-subtle hover:border-accent transition-colors relative flex flex-col justify-between group">
                  <Icon
                    name="ph:quotes"
                    class="absolute top-6 right-6 w-8 h-8 text-muted/15 group-hover:text-accent/30 transition-colors"
                    aria-hidden="true"
                  />
                  <blockquote class="text-sm text-secondary leading-relaxed font-sans italic mb-6 relative z-10">
                    "{t.text}"
                  </blockquote>
                  <div class="border-t border-subtle pt-4 relative z-10">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <cite class="text-sm font-bold text-primary not-italic block">{t.name}</cite>
                        <span
                          class="text-[10px] font-mono text-muted block mt-0.5 truncate max-w-[200px] sm:max-w-[320px]"
                          title={t.role}
                        >
                          {t.role}
                        </span>
                      </div>
                      <span
                        class={`text-[9px] border px-2 py-0.5 rounded font-semibold tracking-wider font-mono uppercase shrink-0 ${
                          t.type === "colleague"
                            ? "bg-purple-500/10 text-purple-400 border-purple-500/20"
                            : "bg-emerald-500/10 text-emerald-400 border-emerald-500/20"
                        }`}
                      >
                        {t.type === "colleague" ? "Colleague" : "WP.org User"}
                      </span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )
      }

      <!-- Volunteering and open-source contributions -->
      <div class="grid md:grid-cols-2 gap-8 mb-24 reveal r4">
        <div class="glass p-8 hover-glow-purple bg-surface flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between mb-4">
              <p class="t-mono text-purple-400 text-[10px] tracking-wider font-bold">COMMUNITY ENGAGEMENT</p>
              <Icon name="ph:users" class="w-5 h-5 text-purple-400" />
            </div>
            <h3 class="font-bold text-base text-primary">Volunteer Developer</h3>
            <p class="text-xs text-muted mt-1 mb-4">Jagadhatri Online &mdash; Aug 2020 - Present</p>
            <p class="text-sm text-secondary leading-relaxed font-sans">
              Volunteered to build and maintain the event and commerce portal utilizing Next.js, managing API sync
              frameworks with local WooCommerce catalogs.
            </p>
          </div>
        </div>

        <div class="glass p-8 hover-glow-rose bg-surface flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between mb-4">
              <p class="t-mono text-rose-400 text-[10px] tracking-wider font-bold">OPEN SOURCE ECOSYSTEM</p>
              <Icon name="ph:git-branch" class="w-5 h-5 text-rose-400" />
            </div>
            <h3 class="font-bold text-base text-primary">Core &amp; Plugin Contributor</h3>
            <p class="text-xs text-muted mt-1 mb-4">WordPress.org &mdash; Jul 2018 - Present</p>
            <p class="text-sm text-secondary leading-relaxed font-sans">
              Submit patches, refactor actions, and provide interface enhancements inside the core WordPress platform,
              supporting open-source development globally.
            </p>
          </div>
        </div>
      </div>

      <!-- Interests -->
      <div class="reveal r5">
        <p class="t-mono text-accent mb-4">Interests</p>
        <h2 class="t-title mb-6">Outside of writing code.</h2>
        <div class="flex flex-wrap gap-3">
          <span
            class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
          >
            <Icon name="ph:music-notes" class="w-4 h-4 text-accent" />
            Music
          </span>
          <span
            class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
          >
            <Icon name="ph:book-open" class="w-4 h-4 text-accent" />
            Reading Books
          </span>
          <span
            class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
          >
            <Icon name="ph:compass" class="w-4 h-4 text-accent" />
            Travel
          </span>
          <span
            class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
          >
            <Icon name="ph:game-controller" class="w-4 h-4 text-accent" />
            Gaming
          </span>
          <span
            class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
          >
            <Icon name="ph:coffee" class="w-4 h-4 text-accent" />
            Coffee
          </span>
          <span
            class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface border border-strong text-sm font-semibold text-primary hover:border-accent hover:text-accent transition-colors"
          >
            <Icon name="ph:brain" class="w-4 h-4 text-accent" />
            Mindfulness
          </span>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

