<header class="fixed top-0 inset-x-0 z-50 transition-all duration-500 py-4" id="site-header">
  <div class="mx">
    <div class="glass glass-glow rounded-2xl flex items-center justify-between px-6 transition-all duration-500" style="height:4rem" id="header-inner">
      <a href="/" class="flex items-center gap-3 group">
        <span class="w-8 h-8 rounded-lg bg-[var(--accent)] flex items-center justify-center text-[var(--bg-deep)] font-bold text-sm shadow-md group-hover:scale-105 transition-transform duration-300">S</span>
        <div class="flex flex-col">
          <span class="font-[var(--font-display)] text-base font-bold tracking-tight text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors duration-300">Sayan Datta</span>
          <div class="flex items-center gap-1.5 mt-0.5">
            <span class="pulse-dot"></span>
            <span class="text-[9px] font-mono tracking-widest text-[var(--success)] uppercase">Available for Hire</span>
          </div>
        </div>
      </a>

      <div class="flex items-center gap-6">
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class="nav-link text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors relative py-1">Home</a>
          <a href="/about-me" class="nav-link text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors relative py-1">About</a>
          <a href="/services" class="nav-link text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors relative py-1">Services</a>
          <a href="/projects" class="nav-link text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors relative py-1">Projects</a>
          <a href="/blog" class="nav-link text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors relative py-1">Blog</a>
          <a href="/contact" class="b b-primary !text-xs !py-2 !px-4 shadow-sm">Contact</a>
        </nav>

        <div class="flex items-center gap-3">
          <button id="theme-toggle" class="w-9 h-9 rounded-lg flex items-center justify-center border border-[var(--border-subtle)] hover:border-[var(--accent)] transition-colors bg-[var(--bg-raised)] cursor-pointer" aria-label="Toggle theme">
            <!-- Sun icon (visible in dark mode) -->
            <svg id="sun-icon" class="w-4 h-4 text-[var(--text-secondary)] transition-transform duration-300 hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"/>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <!-- Moon icon (visible in light mode) -->
            <svg id="moon-icon" class="w-4 h-4 text-[var(--text-secondary)] hidden transition-transform duration-300 hover:-rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
            </svg>
          </button>

          <button id="menu-btn" class="md:hidden w-9 h-9 rounded-lg border border-[var(--border-subtle)] flex flex-col items-center justify-center gap-1.5 bg-[var(--bg-raised)] cursor-pointer" aria-label="Menu">
            <span class="block w-4 h-[2px] bg-[var(--text-primary)] rounded transition-all duration-300 origin-center" id="l1"></span>
            <span class="block w-4 h-[2px] bg-[var(--text-primary)] rounded transition-all duration-300 origin-center" id="l2"></span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mob-menu" class="md:hidden overflow-hidden transition-all duration-400 ease-out px-4 max-h-0 opacity-0">
    <div class="glass p-6 mt-2 flex flex-col gap-4 shadow-lg border-[var(--border-strong)]">
      <a href="/" class="text-[var(--text-secondary)] hover:text-[var(--accent)] text-base font-semibold py-1 transition-colors border-b border-[var(--border-subtle)]" data-close>Home</a>
      <a href="/about-me" class="text-[var(--text-secondary)] hover:text-[var(--accent)] text-base font-semibold py-1 transition-colors border-b border-[var(--border-subtle)]" data-close>About</a>
      <a href="/services" class="text-[var(--text-secondary)] hover:text-[var(--accent)] text-base font-semibold py-1 transition-colors border-b border-[var(--border-subtle)]" data-close>Services</a>
      <a href="/projects" class="text-[var(--text-secondary)] hover:text-[var(--accent)] text-base font-semibold py-1 transition-colors border-b border-[var(--border-subtle)]" data-close>Projects</a>
      <a href="/blog" class="text-[var(--text-secondary)] hover:text-[var(--accent)] text-base font-semibold py-1 transition-colors border-b border-[var(--border-subtle)]" data-close>Blog</a>
      <a href="/contact" class="b b-primary w-full text-center py-2.5 mt-2" data-close>Contact</a>
    </div>
  </div>
</header>

<style>
  /* Header Scrolled styles */
  .scrolled {
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  .scrolled #header-inner {
    background: var(--bg-glass) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border-color: var(--border-strong) !important;
    box-shadow: var(--shadow-glass) !important;
    border-radius: 1rem !important;
  }

  /* Interactive Navigation Link Underline Hover */
  .nav-link::after {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 1.5px;
    bottom: -2px;
    left: 0;
    background-color: var(--accent);
    transform-origin: bottom right;
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }
</style>

<script>
  function initTheme() {
    var tb = document.getElementById("theme-toggle"),
        s = document.getElementById("sun-icon"),
        m = document.getElementById("moon-icon");
        
    if (!tb || !s || !m) return;
    
    function getTheme() {
      var t = localStorage.getItem("theme");
      if (!t) {
        return matchMedia("(prefers-color-scheme:light)").matches ? "light" : "dark";
      }
      return t;
    }
    
    function st(v) {
      var isLight = v === "light";
      document.documentElement.classList.toggle("light", isLight);
      document.documentElement.classList.toggle("light-scrollbar", isLight);
      
      // Update icons visibility:
      // In light mode, show the Moon icon (to switch to dark)
      // In dark mode, show the Sun icon (to switch to light)
      s.classList.toggle("hidden", isLight);
      m.classList.toggle("hidden", !isLight);
    }
    
    st(getTheme());
    
    tb.addEventListener("click", (e) => {
      var c = getTheme();
      var n = c === "light" ? "dark" : "light";
      localStorage.setItem("theme", n);
      
      if ((document as any).startViewTransition) {
        var x = e.clientX || window.innerWidth / 2;
        var y = e.clientY || window.innerHeight / 2;
        var endRadius = Math.hypot(
          Math.max(x, window.innerWidth - x),
          Math.max(y, window.innerHeight - y)
        );
        
        var transition = (document as any).startViewTransition(() => {
          // Inside transition: only update document class light, do NOT toggle light-scrollbar!
          document.documentElement.classList.toggle("light", n === "light");
          s.classList.toggle("hidden", n === "light");
          m.classList.toggle("hidden", n !== "light");
        });
        
        transition.ready.then(() => {
          document.documentElement.animate(
            {
              clipPath: [
                "circle(0px at " + x + "px " + y + "px)",
                "circle(" + endRadius + "px at " + x + "px " + y + "px)"
              ]
            },
            {
              duration: 450,
              easing: "cubic-bezier(0.4, 0, 0.2, 1)",
              pseudoElement: "::view-transition-new(root)"
            }
          );
        });
        
        transition.finished.then(() => {
          // Toggle scrollbar color-scheme once transition has finished sweeping
          document.documentElement.classList.toggle("light-scrollbar", n === "light");
        });
      } else {
        st(n);
      }
    });
    
    matchMedia("(prefers-color-scheme:light)").addEventListener("change", () => {
      if (!localStorage.getItem("theme")) {
        st(matchMedia("(prefers-color-scheme:light)").matches ? "light" : "dark");
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTheme);
  } else {
    initTheme();
  }

  // Mobile Menu Menu Logic
  var tg = document.getElementById("menu-btn"),
      mn = document.getElementById("mob-menu"),
      l1 = document.getElementById("l1"),
      l2 = document.getElementById("l2"),
      o = false;
      
  tg.addEventListener("click", () => {
    o = !o;
    mn.style.maxHeight = o ? "400px" : "0";
    mn.style.opacity = o ? "1" : "0";
    l1.style.transform = o ? "rotate(45deg) translate(4px, 4px)" : "";
    l2.style.transform = o ? "rotate(-45deg) translate(4px, -4px)" : "";
  });
  
  document.querySelectorAll("[data-close]").forEach(e => e.addEventListener("click", () => {
    o = false;
    mn.style.maxHeight = "0";
    mn.style.opacity = "0";
    l1.style.transform = "";
    l2.style.transform = "";
  }));

  // Scroll Behavior
  var h = document.getElementById("site-header");
  addEventListener("scroll", () => {
    h.classList.toggle("scrolled", scrollY > 10);
  }, { passive: true });
</script>
