---
import { getProfile } from "@/lib/data";
import { Icon } from "astro-icon/components";
import { Toggle } from "astro-theme-toggle/components";

const profile = await getProfile();
const initialLetter = profile.name.charAt(0);
const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === "/") {
    return pathname === "/" || pathname === "";
  }
  return pathname.startsWith(path);
};
---

<header class="fixed top-0 inset-x-0 z-50 transition-all duration-500 py-4" id="site-header">
  <!-- Skip to Content link for keyboard accessibility -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:z-[999] focus:top-6 focus:left-6 focus:bg-accent focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-xl focus:outline-none"
    >Skip to Content</a
  >

  <div class="mx">
    <div
      class="glass glass-glow rounded-2xl flex items-center justify-between px-6 transition-all duration-500"
      style="height:4rem"
      id="header-inner"
    >
      <a href="/" class="flex items-center gap-3 group">
        <span
          class="w-8 h-8 rounded-lg bg-accent flex items-center justify-center text-deep font-bold text-sm shadow-md group-hover:scale-105 transition-transform duration-300"
          >{initialLetter}</span
        >
        <div class="flex flex-col">
          <span
            class="font-[var(--font-display)] text-base font-bold tracking-tight text-primary group-hover:text-accent transition-colors duration-300"
            >{profile.name}</span
          >
          <div class="flex items-center gap-1.5 mt-0.5" aria-hidden="true">
            <span class="pulse-dot"></span>
            <span class="text-[9px] font-mono tracking-widest text-success uppercase">Available for Hire</span>
          </div>
        </div>
      </a>

      <div class="flex items-center gap-6">
        <nav class="hidden md:flex items-center gap-8" aria-label="Main Navigation">
          <a
            href="/"
            class={`nav-link text-sm font-medium transition-colors relative py-1 ${isActive("/") ? "text-accent font-semibold active-nav" : "text-secondary hover:text-accent"}`}
            aria-current={isActive("/") ? "page" : undefined}>Home</a
          >
          <a
            href="/about-me"
            class={`nav-link text-sm font-medium transition-colors relative py-1 ${isActive("/about-me") ? "text-accent font-semibold active-nav" : "text-secondary hover:text-accent"}`}
            aria-current={isActive("/about-me") ? "page" : undefined}>About</a
          >
          <a
            href="/skills"
            class={`nav-link text-sm font-medium transition-colors relative py-1 ${isActive("/skills") ? "text-accent font-semibold active-nav" : "text-secondary hover:text-accent"}`}
            aria-current={isActive("/skills") ? "page" : undefined}>Skills</a
          >
          <a
            href="/services"
            class={`nav-link text-sm font-medium transition-colors relative py-1 ${isActive("/services") ? "text-accent font-semibold active-nav" : "text-secondary hover:text-accent"}`}
            aria-current={isActive("/services") ? "page" : undefined}>Services</a
          >
          <a
            href="/projects"
            class={`nav-link text-sm font-medium transition-colors relative py-1 ${isActive("/projects") ? "text-accent font-semibold active-nav" : "text-secondary hover:text-accent"}`}
            aria-current={isActive("/projects") ? "page" : undefined}>Projects</a
          >
          <a
            href="/blog"
            class={`nav-link text-sm font-medium transition-colors relative py-1 ${isActive("/blog") ? "text-accent font-semibold active-nav" : "text-secondary hover:text-accent"}`}
            aria-current={isActive("/blog") ? "page" : undefined}>Blog</a
          >
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link text-sm font-medium text-secondary hover:text-accent transition-colors relative py-1"
            >Resume</a
          >
          <a
            href="/contact"
            class={`b b-primary !text-xs !py-2 !px-4 shadow-sm ${isActive("/contact") ? "ring-2 ring-accent" : ""}`}
            aria-current={isActive("/contact") ? "page" : undefined}>Contact</a
          >
        </nav>

        <div class="flex items-center gap-2.5">
          <Toggle
            class="w-9 h-9 rounded-lg flex items-center justify-center border border-subtle hover:border-accent transition-colors bg-raised"
            aria-label="Toggle theme"
          >
            <Fragment slot="icon-light">
              <Icon
                name="ph:moon"
                class="w-4 h-4 text-secondary transition-transform duration-300 hover:-rotate-12"
                aria-hidden="true"
              />
            </Fragment>
            <Fragment slot="icon-dark">
              <Icon
                name="ph:sun"
                class="w-4 h-4 text-secondary transition-transform duration-300 hover:rotate-45"
                aria-hidden="true"
              />
            </Fragment>
          </Toggle>

          <button
            id="menu-btn"
            class="md:hidden w-9 h-9 rounded-lg border border-subtle flex flex-col items-center justify-center gap-1.5 bg-raised cursor-pointer"
            aria-label="Toggle Mobile Menu"
            aria-expanded="false"
            aria-controls="mob-menu"
          >
            <span
              class="block w-4 h-[2px] bg-primary rounded transition-all duration-300 origin-center"
              id="l1"
              aria-hidden="true"></span>
            <span
              class="block w-4 h-[2px] bg-primary rounded transition-all duration-300 origin-center"
              id="l2"
              aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mob-menu"
    class="md:hidden overflow-hidden transition-all duration-400 ease-out px-4 max-h-0 opacity-0"
    aria-label="Mobile Navigation"
  >
    <div class="glass p-6 mt-2 flex flex-col gap-4 shadow-lg border-strong">
      <a
        href="/"
        class={`text-base font-semibold py-1 transition-colors border-b border-subtle ${isActive("/") ? "text-accent" : "text-secondary hover:text-accent"}`}
        data-close
        aria-current={isActive("/") ? "page" : undefined}>Home</a
      >
      <a
        href="/about-me"
        class={`text-base font-semibold py-1 transition-colors border-b border-subtle ${isActive("/about-me") ? "text-accent" : "text-secondary hover:text-accent"}`}
        data-close
        aria-current={isActive("/about-me") ? "page" : undefined}>About</a
      >
      <a
        href="/skills"
        class={`text-base font-semibold py-1 transition-colors border-b border-subtle ${isActive("/skills") ? "text-accent" : "text-secondary hover:text-accent"}`}
        data-close
        aria-current={isActive("/skills") ? "page" : undefined}>Skills</a
      >
      <a
        href="/services"
        class={`text-base font-semibold py-1 transition-colors border-b border-subtle ${isActive("/services") ? "text-accent" : "text-secondary hover:text-accent"}`}
        data-close
        aria-current={isActive("/services") ? "page" : undefined}>Services</a
      >
      <a
        href="/projects"
        class={`text-base font-semibold py-1 transition-colors border-b border-subtle ${isActive("/projects") ? "text-accent" : "text-secondary hover:text-accent"}`}
        data-close
        aria-current={isActive("/projects") ? "page" : undefined}>Projects</a
      >
      <a
        href="/blog"
        class={`text-base font-semibold py-1 transition-colors border-b border-subtle ${isActive("/blog") ? "text-accent" : "text-secondary hover:text-accent"}`}
        data-close
        aria-current={isActive("/blog") ? "page" : undefined}>Blog</a
      >
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="text-secondary hover:text-accent text-base font-semibold py-1 transition-colors border-b border-subtle"
        data-close>View Resume</a
      >
      <a
        href="/resume.pdf"
        download
        class="text-secondary hover:text-accent text-base font-semibold py-1 transition-colors border-b border-subtle"
        data-close>Download Resume</a
      >
      <a
        href="/contact"
        class="b b-primary w-full text-center py-2.5 mt-2"
        data-close
        aria-current={isActive("/contact") ? "page" : undefined}>Contact</a
      >
    </div>
  </div>
</header>

<style>
  /* Header Scrolled styles */
  .scrolled {
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  .scrolled #header-inner {
    background: var(--bg-glass) !important;
    backdrop-filter: blur(24px) !important;
    -webkit-backdrop-filter: blur(24px) !important;
    border-color: var(--border-strong) !important;
    box-shadow: var(--shadow-glass) !important;
    border-radius: 1rem !important;
  }

  /* Interactive Navigation Link Underline Hover */
  .nav-link::after {
    content: "";
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 1.5px;
    bottom: -2px;
    left: 0;
    background-color: var(--accent);
    transform-origin: bottom right;
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .nav-link:hover::after,
  .active-nav::after {
    transform: scaleX(1) !important;
    transform-origin: bottom left;
  }
</style>

<script>
  // Mobile Menu Logic with accessibility support
  const tg = document.getElementById("menu-btn");
  const mn = document.getElementById("mob-menu");
  const l1 = document.getElementById("l1");
  const l2 = document.getElementById("l2");
  let o = false;

  if (tg && mn && l1 && l2) {
    tg.addEventListener("click", () => {
      o = !o;
      tg.setAttribute("aria-expanded", o ? "true" : "false");
      mn.style.maxHeight = o ? "460px" : "0";
      mn.style.opacity = o ? "1" : "0";
      l1.style.transform = o ? "rotate(45deg) translate(4px, 4px)" : "";
      l2.style.transform = o ? "rotate(-45deg) translate(4px, -4px)" : "";
    });

    document.querySelectorAll("[data-close]").forEach((e) =>
      e.addEventListener("click", () => {
        o = false;
        tg.setAttribute("aria-expanded", "false");
        mn.style.maxHeight = "0";
        mn.style.opacity = "0";
        l1.style.transform = "";
        l2.style.transform = "";
      })
    );
  }

  // Scroll Behavior
  const h = document.getElementById("site-header");
  if (h) {
    addEventListener(
      "scroll",
      () => {
        h.classList.toggle("scrolled", scrollY > 10);
      },
      { passive: true }
    );
  }
</script>
