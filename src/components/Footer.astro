---
import { getProfile } from "@/lib/data";
const profile = await getProfile();
---
<footer class="border-t border-[var(--border-subtle)] bg-[var(--bg-surface)] mt-auto">
  <!-- Footer Quick CTA Section -->
  <div class="mx py-16">
    <div class="glass p-8 md:p-12 relative overflow-hidden border-[var(--border-strong)] flex flex-col md:flex-row items-center justify-between gap-8 mb-16">
      <div class="absolute inset-0 opacity-[.06] pointer-events-none" style="background:radial-gradient(circle at 85% 85%, var(--accent), transparent 60%)"></div>
      <div class="z-10 text-center md:text-left">
        <h3 class="t-title text-xl md:text-2xl font-bold text-[var(--text-primary)]">Start a new project with me</h3>
        <p class="t-body-sm mt-2 max-w-lg">I'm currently accepting select freelance projects, agency contract roles, and open source opportunities.</p>
      </div>
      <div class="z-10 flex-shrink-0">
        <a href="/contact" class="b b-primary shadow-md hover:scale-105 transition-transform duration-300">
          Get in Touch
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>

    <!-- Main Footer Grid -->
    <div class="grid sm:grid-cols-12 gap-10">
      <div class="sm:col-span-5">
        <a href="/" class="flex items-center gap-2 group">
          <span class="w-7 h-7 rounded-md bg-[var(--accent)] flex items-center justify-center text-[var(--bg-deep)] font-bold text-xs">S</span>
          <span class="font-[var(--font-display)] font-bold tracking-tight text-[var(--text-primary)]">Sayan Datta</span>
        </a>
        <p class="t-body-sm mt-4 max-w-xs leading-relaxed">Full Stack Developer &amp; WordPress Expert. Specializing in custom plugins, web applications, and performant headless architectures.</p>
        
        <!-- Local Time Indicator (High-End Feature) -->
        <div class="mt-6 inline-flex items-center gap-2 px-3.5 py-1.5 rounded-lg bg-[var(--bg-raised)] border border-[var(--border-subtle)]">
          <span class="w-2 h-2 rounded-full bg-[var(--success)] animate-pulse"></span>
          <span class="text-xs font-mono text-[var(--text-secondary)]">
            India (UTC+5:30) · <span id="local-time">--:--:--</span>
          </span>
        </div>
      </div>
      
      <div class="sm:col-span-3 sm:col-start-7">
        <p class="t-mono mb-4 text-xs font-bold text-[var(--text-primary)]">Navigation</p>
        <div class="space-y-2.5">
          <a href="/" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Home</a>
          <a href="/about-me" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">About</a>
          <a href="/skills" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Skills</a>
          <a href="/services" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Services</a>
          <a href="/projects" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Projects</a>
          <a href="/blog" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Blog</a>
          <a href="/contact" class="block text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Contact</a>
        </div>
      </div>
      
      <div class="sm:col-span-3">
        <p class="t-mono mb-4 text-xs font-bold text-[var(--text-primary)]">Connect</p>
        <div class="space-y-2.5">
          <a href={profile.socials.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z" clip-rule="evenodd"/></svg>
            GitHub
          </a>
          <a href={profile.socials.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            LinkedIn
          </a>
          <a href={profile.socials.twitter} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter / X
          </a>
          <a href={`mailto:${profile.email}`} class="block text-sm text-[var(--accent)] hover:text-[var(--accent-bright)] transition-colors mt-4 font-semibold">
            {profile.email}
          </a>
        </div>
      </div>
    </div>
    
    <div class="py-6">
      <hr class="hr" />
    </div>
    
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="t-mono text-xs text-center sm:text-left">© {new Date().getFullYear()} Sayan Datta. All rights reserved.</p>
      <p class="t-mono text-[10px] text-[var(--text-muted)] flex items-center gap-1.5">
        Built with Astro &amp; Tailwind CSS v4
      </p>
    </div>
  </div>
</footer>

<script>
  function updateTime() {
    const el = document.getElementById("local-time");
    if (!el) return;
    
    const options = {
      timeZone: "Asia/Kolkata",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: true
    };
    
    try {
      const timeStr = new Date().toLocaleTimeString("en-US", options);
      el.textContent = timeStr;
    } catch (e) {
      // Fallback
      const d = new Date();
      el.textContent = d.toUTCString();
    }
  }
  
  // Start clock
  updateTime();
  setInterval(updateTime, 1000);
</script>
