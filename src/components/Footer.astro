---
import { getProfile } from "@/lib/data";
const profile = await getProfile();
---
<footer class="border-t border-subtle bg-deep relative overflow-hidden mt-auto">
  <!-- Glowing ambient light spotlight -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[250px] rounded-full bg-[radial-gradient(circle,var(--accent-glow-strong)_0%,transparent_70%)] opacity-30 blur-2xl pointer-events-none" aria-hidden="true"></div>

  <!-- Footer Quick CTA Section -->
  <div class="mx pt-16">
    <div class="glass hover-glow-rose p-8 md:p-12 relative overflow-hidden bg-surface border-strong flex flex-col md:flex-row items-center justify-between gap-8 mb-16 rounded-2xl">
      <!-- Glow behind button -->
      <div class="absolute right-0 bottom-0 opacity-[0.05] w-[300px] h-[300px] bg-accent rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="z-10 text-center md:text-left">
        <span class="text-[10px] font-mono tracking-wider text-accent uppercase font-bold block mb-1">Collaboration</span>
        <h3 class="t-title text-xl md:text-2xl font-black text-primary font-sans">Start a new project with me</h3>
        <p class="text-xs text-secondary mt-2 max-w-lg font-sans">
          I'm currently accepting select freelance projects, agency contract roles, and headless integration opportunities.
        </p>
      </div>
      <div class="z-10 flex-shrink-0">
        <a href="/contact" class="b b-primary shadow-lg hover:scale-105 transition-transform duration-300 flex items-center gap-2">
          Get in Touch
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>

    <!-- Bento Grid Style Footer Layout -->
    <div class="grid lg:grid-cols-12 gap-8 mb-16 border-b border-subtle pb-16">
      
      <!-- Brand & Status Panel -->
      <div class="lg:col-span-5 space-y-6">
        <div>
          <a href="/" class="flex items-center gap-2.5 group w-fit">
            <span class="w-8 h-8 rounded-lg bg-accent flex items-center justify-center text-deep font-bold text-sm shadow-md group-hover:rotate-6 transition-transform">S</span>
            <span class="font-sans font-extrabold tracking-tight text-primary text-md">Sayan Datta</span>
          </a>
          <p class="text-xs text-secondary mt-4 max-w-sm leading-relaxed font-sans">
            Full Stack Developer specializing in high-performance WooCommerce plugin architectures, custom payment gateways, secure Laravel backends, and modern frontend systems.
          </p>
        </div>

        <!-- Telemetry Radar / Time Status -->
        <div class="glass p-4 bg-surface border-subtle rounded-xl flex items-center justify-between gap-4 max-w-sm">
          <div class="flex items-center gap-3">
            <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
            </span>
            <div>
              <span class="text-[9px] font-mono text-muted uppercase block">Kolkata, IN</span>
              <span id="local-time" class="text-xs font-mono text-primary font-bold">--:--:--</span>
            </div>
          </div>
          <div class="text-right border-l border-subtle pl-4">
            <span class="text-[8px] font-mono text-muted uppercase block">Sys Health</span>
            <span class="text-[10px] font-mono text-success font-semibold">Operational</span>
          </div>
        </div>
      </div>

      <!-- Quick Directory Navigation -->
      <div class="lg:col-span-3 lg:col-start-7 space-y-4">
        <span class="text-[10px] font-mono text-primary uppercase font-bold tracking-wider block border-b border-subtle pb-2">Directory</span>
        <div class="grid grid-cols-2 gap-x-4 gap-y-2">
          <a href="/" class="text-xs text-secondary hover:text-accent transition-colors flex items-center gap-1 group">
            <span class="text-muted group-hover:text-accent font-mono text-[9px]">&gt;</span> Home
          </a>
          <a href="/about-me" class="text-xs text-secondary hover:text-accent transition-colors flex items-center gap-1 group">
            <span class="text-muted group-hover:text-accent font-mono text-[9px]">&gt;</span> About
          </a>
          <a href="/skills" class="text-xs text-secondary hover:text-accent transition-colors flex items-center gap-1 group">
            <span class="text-muted group-hover:text-accent font-mono text-[9px]">&gt;</span> Skills
          </a>
          <a href="/services" class="text-xs text-secondary hover:text-accent transition-colors flex items-center gap-1 group">
            <span class="text-muted group-hover:text-accent font-mono text-[9px]">&gt;</span> Services
          </a>
          <a href="/projects" class="text-xs text-secondary hover:text-accent transition-colors flex items-center gap-1 group">
            <span class="text-muted group-hover:text-accent font-mono text-[9px]">&gt;</span> Projects
          </a>
          <a href="/blog" class="text-xs text-secondary hover:text-accent transition-colors flex items-center gap-1 group">
            <span class="text-muted group-hover:text-accent font-mono text-[9px]">&gt;</span> Blog
          </a>
          <a href="/contact" class="text-xs text-secondary hover:text-accent transition-colors flex items-center gap-1 group" style="grid-column: span 2;">
            <span class="text-muted group-hover:text-accent font-mono text-[9px]">&gt;</span> Contact
          </a>
        </div>
      </div>

      <!-- Developer Connect & Profiles Panel -->
      <div class="lg:col-span-3 space-y-4">
        <span class="text-[10px] font-mono text-primary uppercase font-bold tracking-wider block border-b border-subtle pb-2">Connect Channels</span>
        <div class="space-y-3">
          <a href={profile.socials.github} target="_blank" rel="noopener noreferrer" class="glass px-3 py-2 bg-surface hover:border-accent flex items-center justify-between text-xs text-secondary hover:text-accent transition-all rounded-lg group" aria-label="GitHub Profile">
            <span class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z" clip-rule="evenodd"/></svg>
              GitHub
            </span>
            <span class="text-[9px] font-mono opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">&rarr;</span>
          </a>
          <a href={profile.socials.linkedin} target="_blank" rel="noopener noreferrer" class="glass px-3 py-2 bg-surface hover:border-accent flex items-center justify-between text-xs text-secondary hover:text-accent transition-all rounded-lg group" aria-label="LinkedIn Profile">
            <span class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              LinkedIn
            </span>
            <span class="text-[9px] font-mono opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">&rarr;</span>
          </a>
          <a href={profile.socials.twitter} target="_blank" rel="noopener noreferrer" class="glass px-3 py-2 bg-surface hover:border-accent flex items-center justify-between text-xs text-secondary hover:text-accent transition-all rounded-lg group" aria-label="Twitter Profile">
            <span class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter / X
            </span>
            <span class="text-[9px] font-mono opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Health Indicators & Copyright Metadata -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 pb-12">
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <p class="text-[10px] font-mono text-secondary">© {new Date().getFullYear()} Sayan Datta. All rights reserved.</p>
        <span class="text-muted hidden md:inline" aria-hidden="true">|</span>
        <a href="/resume.pdf" class="text-[10px] font-mono text-muted hover:text-accent" target="_blank" rel="noopener noreferrer">print_resume.pdf</a>
        <span class="text-muted hidden md:inline" aria-hidden="true">|</span>
        <a href="/robots.txt" class="text-[10px] font-mono text-muted hover:text-accent" target="_blank" rel="noopener noreferrer">robots.txt</a>
      </div>
      <div class="flex items-center gap-4 flex-wrap justify-center select-none" aria-label="System telemetry stats" role="group">
        <span class="text-[9px] font-mono px-2 py-0.5 rounded bg-surface border border-subtle text-muted">build: passing</span>
        <span class="text-[9px] font-mono px-2 py-0.5 rounded bg-surface border border-subtle text-muted">nodes: sitemap (11)</span>
        <span class="text-[9px] font-mono px-2 py-0.5 rounded bg-surface border border-subtle text-muted">engine: Astro v7</span>
      </div>
    </div>
  </div>
</footer>

<script>
  function updateTime() {
    const el = document.getElementById("local-time");
    if (!el) return;
    
    const options: Intl.DateTimeFormatOptions = {
      timeZone: "Asia/Kolkata",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: true
    };
    
    try {
      const timeStr = new Date().toLocaleTimeString("en-US", options);
      el.textContent = timeStr;
    } catch (e) {
      const d = new Date();
      el.textContent = d.toUTCString();
    }
  }
  
  // Start clock
  updateTime();
  setInterval(updateTime, 1000);
</script>
